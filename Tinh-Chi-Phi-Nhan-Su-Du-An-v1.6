// ============================================================
// ===== v1.5: QUICK CALCULATOR (Tính Phổ Thông) =====
// Dựa trên Báo cáo Định biên Nhân sự 2026
// ============================================================

// Hệ số biến động thời gian — Dựa trên Brooks's Law và kinh nghiệm thực tế
const TIME_SCENARIOS = {
  normal:   { coef: 1.00, desc: 'Chuẩn — Theo tiến độ kế hoạch' },
  extend10: { coef: 1.05, desc: 'Kéo dài 10% — Bộ máy QL duy trì lâu hơn' },
  extend25: { coef: 1.12, desc: 'Kéo dài 25% — Phụ phí cố định tăng vừa' },
  extend50: { coef: 1.22, desc: 'Kéo dài 50% — Chi phí cố định tăng đáng kể' },
  crash10:  { coef: 1.08, desc: 'Rút 10% — Tăng ca, thêm 1 ca/ngày' },
  crash25:  { coef: 1.20, desc: 'Rút 25% — Fast-track, thêm GS' },
  crash40:  { coef: 1.35, desc: 'Rút 40% — Crash schedule, 3 ca' },
  custom:   { coef: 1.00, desc: 'Tùy chỉnh' },
};

// Tham số chuẩn theo loại hình (từ Báo cáo Định biên 2026)
// QC_DEFAULTS và onQuickTypeChange định nghĩa trong SYNC ENGINE ở trên

function reloadQuickDefaults(){
  const t = document.getElementById('qcType').value;
  const d = QC_DEFAULTS[t];
  if (!d) return;
  document.getElementById('qcR').value = d.R.toFixed(2);
  document.getElementById('qcL').value = d.L.toFixed(1);
  document.getElementById('qcN').value = '';
  updateQuickCalc();
}

function applyTimeScenario(){
  const sc = document.getElementById('qcTimeScenario').value;
  if (sc === 'custom') {
    // Giữ giá trị custom hiện tại
    updateQuickCalc();
    return;
  }
  const cfg = TIME_SCENARIOS[sc];
  if (!cfg) return;
  document.getElementById('qcTimeCoef').value = cfg.coef.toFixed(2);
  updateQuickCalc();
}

function onTimeCoefChange(){
  document.getElementById('qcTimeScenario').value = 'custom';
  updateQuickCalc();
}

function qcAutoN(){
  // Tự tính N từ R, GTT, L, T
  const v = getQuickInputs();
  const QL_million = v.GTT * 1000 * v.R / 100;  // QL theo triệu VND (vì L tính bằng triệu)
  const N = (v.L * v.T) > 0 ? Math.round(QL_million / (v.L * v.T)) : 0;
  document.getElementById('qcN').value = N;
  updateQuickCalc();
}

function getQuickInputs(){
  // Đọc trực tiếp từ APP_STATE — luôn đồng bộ
  return {
    type:     APP_STATE.projectType,
    GTT:      APP_STATE.projectValue,
    T:        APP_STATE.duration,
    L:        APP_STATE.qcL,
    R:        APP_STATE.qcR,
    N:        APP_STATE.qcN,
    timeCoef: APP_STATE.timeCoef,
  };
}

function updateQuickCalc(){
  const v = getQuickInputs();
  const d = QC_DEFAULTS[v.type];

  // CT [1]: QL (chuẩn, chưa hiệu chỉnh thời gian) = GTT × R, đơn vị tỷ VND
  const QL_base_billion = v.GTT * v.R / 100;
  // Đổi sang triệu để khớp đơn vị L
  const QL_base_million = QL_base_billion * 1000;

  // CT [2]: N từ QL/L/T (nếu user không override)
  const N_auto = (v.L * v.T) > 0 ? Math.round(QL_base_million / (v.L * v.T)) : 0;
  const N_used = (v.N !== null && v.N > 0) ? v.N : N_auto;

  // CT [3]: L kiểm tra (back-calc)
  const L_check = (N_used * v.T) > 0 ? (QL_base_million / (N_used * v.T)) : 0;

  // CT [4]: Năng suất lao động
  const NSLD_year = N_used > 0 ? (v.GTT / N_used * 12 / v.T) : 0; // tỷ/người/năm
  const NSLD_proj = N_used > 0 ? (v.GTT / N_used) : 0;            // tỷ/người/dự án

  // CT [5]: Hồi quy nhanh
  const N_reg = 0.034 * v.GTT + 16.96;

  // Hiệu chỉnh thời gian
  const QL_adj_billion = QL_base_billion * v.timeCoef;
  const QL_adj_million = QL_adj_billion * 1000;
  const R_adj = v.R * v.timeCoef;

  // So sánh với chuẩn loại hình
  const isStandardR = Math.abs(v.R - d.R) < 0.01;
  const isStandardL = Math.abs(v.L - d.L) < 0.1;

  let html = '';

  // Top cards
  html += '<div class="summary-grid" style="margin-bottom:14px">';
  html += '<div class="card" style="border-left:4px solid #065f46"><div class="card-val" style="color:#065f46;font-size:20px">'+QL_base_billion.toFixed(2)+' tỷ</div><div class="card-label">QL Định biên (chuẩn)</div><div class="card-sub">= '+v.GTT+' × '+v.R+'%</div></div>';
  html += '<div class="card" style="border-left:4px solid #9a3412"><div class="card-val" style="color:#9a3412;font-size:20px">'+QL_adj_billion.toFixed(2)+' tỷ</div><div class="card-label">QL Hiệu chỉnh thời gian (×'+v.timeCoef.toFixed(2)+')</div><div class="card-sub">% hiệu chỉnh: '+R_adj.toFixed(2)+'%</div></div>';
  html += '<div class="card" style="border-left:4px solid #0f3460"><div class="card-val" style="color:#0f3460;font-size:20px">'+N_used+' người</div><div class="card-label">N — Số nhân sự</div><div class="card-sub">'+(v.N ? 'User nhập' : 'Auto-tính từ QL/L/T')+'</div></div>';
  html += '<div class="card" style="border-left:4px solid #7b2cbf"><div class="card-val" style="color:#7b2cbf;font-size:20px">'+L_check.toFixed(1)+' tr</div><div class="card-label">L — Kiểm tra (back-calc)</div><div class="card-sub">L mong muốn: '+v.L.toFixed(1)+' tr</div></div>';
  html += '<div class="card" style="border-left:4px solid #0a9396"><div class="card-val" style="color:#0a9396;font-size:20px">'+NSLD_year.toFixed(2)+' tỷ/ng/năm</div><div class="card-label">Năng suất Lao động</div><div class="card-sub">Chuẩn: 15 tỷ/ng/năm '+(NSLD_year >= 15 ? '✅' : '⚠️ Thấp')+'</div></div>';
  html += '<div class="card" style="border-left:4px solid #f59e0b"><div class="card-val" style="color:#f59e0b;font-size:20px">'+Math.round(N_reg)+' người</div><div class="card-label">N theo Hồi quy</div><div class="card-sub">N = 0.034×GTT + 16.96</div></div>';
  html += '</div>';

  // Detail table
  html += '<div style="background:#f8fafc;padding:14px;border-radius:10px;font-size:13px;line-height:2">';
  html += '<b style="color:#0f3460;font-size:13px">📐 CHI TIẾT TÍNH TOÁN:</b><br>';
  html += '<div class="info-row"><span>[1] Quỹ lương = GTT × R</span><b>'+v.GTT+' tỷ × '+v.R+'% = '+QL_base_billion.toFixed(2)+' tỷ VND</b></div>';
  html += '<div class="info-row"><span>[2] N = QL ÷ (L × T)</span><b>'+QL_base_million.toFixed(0)+' tr ÷ ('+v.L+' tr × '+v.T+' th) = '+N_auto+' người</b></div>';
  html += '<div class="info-row"><span>[3] L = QL ÷ (N × T) (back-calc)</span><b>'+QL_base_million.toFixed(0)+' tr ÷ ('+N_used+' × '+v.T+' th) = '+L_check.toFixed(2)+' tr</b></div>';
  html += '<div class="info-row"><span>[4] NSLĐ = GTT ÷ N</span><b>'+v.GTT+' tỷ ÷ '+N_used+' ng = '+NSLD_proj.toFixed(3)+' tỷ/ng/DA = '+NSLD_year.toFixed(2)+' tỷ/ng/năm</b></div>';
  html += '<div class="info-row"><span>[5] N hồi quy = 0.034×GTT+16.96</span><b>'+N_reg.toFixed(1)+' người (tham chiếu)</b></div>';
  html += '<div class="info-row" style="background:#fef3c7;margin:6px -8px;padding:6px 8px;border-radius:6px"><span>⏱️ Hệ số biến động thời gian</span><b style="color:#9a3412">×'+v.timeCoef.toFixed(2)+'</b></div>';
  html += '<div class="info-row" style="background:#fee2e2;margin:6px -8px;padding:6px 8px;border-radius:6px"><span><b>💰 QL HIỆU CHỈNH (cuối cùng)</b></span><b style="color:#e94560;font-size:14px">'+QL_adj_billion.toFixed(2)+' tỷ VND</b></div>';
  html += '<div class="info-row"><span>📊 % hiệu chỉnh trên GTT</span><b style="color:#9a3412">'+R_adj.toFixed(2)+'% (gốc '+v.R+'%)</b></div>';
  html += '</div>';

  // Comparison with standard
  if (!isStandardR || !isStandardL) {
    html += '<div style="margin-top:10px;padding:10px;background:#dbeafe;border-radius:8px;font-size:12px;color:#1e40af">';
    html += '<b>📍 So với chuẩn '+d.label+':</b> ';
    if (!isStandardR) html += 'R hiện tại '+v.R+'% '+(v.R > d.R ? 'CAO HƠN' : 'THẤP HƠN')+' chuẩn '+d.R+'% (Δ '+(v.R-d.R>0?'+':'')+(v.R-d.R).toFixed(2)+'%). ';
    if (!isStandardL) html += 'L hiện tại '+v.L+' tr '+(v.L > d.L ? 'CAO HƠN' : 'THẤP HƠN')+' chuẩn '+d.L+' tr (Δ '+(v.L-d.L>0?'+':'')+(v.L-d.L).toFixed(1)+' tr).';
    html += '</div>';
  }

  document.getElementById('qcResults').innerHTML = html;
  renderQcRuleTable();
}

function renderQcRuleTable(){
  const v = getQuickInputs();
  const rules = [
    { name:'1:4:5', ql:1, cv:4, nv:5, desc:'Agile/PMBOK 7 - Quality-focused' },
    { name:'1:3:6', ql:1, cv:3, nv:6, desc:'Traditional/Waterfall - Phổ biến' },
    { name:'1:2:7', ql:1, cv:2, nv:7, desc:'Heavy-execution' },
    { name:'1:5:4', ql:1, cv:5, nv:4, desc:'Quality-heavy' },
  ];

  // Lấy N hiện tại
  const v2 = getQuickInputs();
  const QL_million = v2.GTT * 1000 * v2.R / 100;
  const N_auto = (v2.L * v2.T) > 0 ? Math.round(QL_million / (v2.L * v2.T)) : 0;
  const N = (v2.N !== null && v2.N > 0) ? v2.N : N_auto;

  let html = '<div class="tbl-wrap"><table class="rule-compare-tbl"><thead><tr>';
  html += '<th style="text-align:left">Quy tắc</th><th>QL</th><th>CV</th><th>NV</th><th>Tổng</th><th>Đặc điểm</th>';
  html += '</tr></thead><tbody>';

  rules.forEach(r => {
    const sum = r.ql + r.cv + r.nv;
    const ql = Math.round(N * r.ql / sum);
    const cv = Math.round(N * r.cv / sum);
    const nv = N - ql - cv;
    html += '<tr>';
    html += '<td class="rule-name"><b>'+r.name+'</b></td>';
    html += '<td style="font-weight:800;color:#f59e0b">'+ql+'</td>';
    html += '<td style="font-weight:800;color:#3b82f6">'+cv+'</td>';
    html += '<td style="font-weight:800;color:#22c55e">'+nv+'</td>';
    html += '<td style="font-weight:800">'+N+'</td>';
    html += '<td style="text-align:left;font-size:11px;color:#666">'+r.desc+'</td>';
    html += '</tr>';
  });
  html += '</tbody></table></div>';
  html += '<div class="notice" style="margin-top:8px">💡 Với N = <b>'+N+' người</b> được tính từ QL và L, áp các quy tắc tỷ lệ để phân vào ngạch QL/CV/NV.</div>';
  document.getElementById('qcRuleTable').innerHTML = html;
}

function applyQuickToStaff(){
  // Lấy N từ quick calc và áp dụng phân bổ tự động 1:3:6 (mặc định) vào staff
  const v = getQuickInputs();
  const QL_million = v.GTT * 1000 * v.R / 100;
  const N_auto = (v.L * v.T) > 0 ? Math.round(QL_million / (v.L * v.T)) : 0;
  const N = (v.N !== null && v.N > 0) ? v.N : N_auto;

  if (N <= 0) { alert('⚠️ Không thể tính được số nhân sự từ tham số hiện tại.'); return; }

  // Đồng bộ tab Phân bổ Tự động
  document.getElementById('totalStaffCount').value = N;
  // Đồng bộ tiến độ + loại hình + GTT vào tab Thông tin
  document.getElementById('projectDuration').value = v.T;
  document.getElementById('projectValue').value = v.GTT;
  document.getElementById('projectType').value = v.type;

  updateAll();
  switchTab('auto');
  setTimeout(() => updateAutoAllocation(), 100);
  alert('✅ Đã chuyển sang tab Phân bổ Tự động với N='+N+' người, T='+v.T+' tháng, GTT='+v.GTT+' tỷ.\nBạn có thể chọn quy tắc 1:N:M và bấm "Áp dụng" để vào bảng nhân sự.');
}

function exportQuickCSV(){
  const v = getQuickInputs();
  const d = QC_DEFAULTS[v.type];
  const QL_base_billion = v.GTT * v.R / 100;
  const QL_adj_billion = QL_base_billion * v.timeCoef;
  const QL_million = QL_base_billion * 1000;
  const N_auto = (v.L * v.T) > 0 ? Math.round(QL_million / (v.L * v.T)) : 0;
  const N_used = (v.N !== null && v.N > 0) ? v.N : N_auto;
  const L_check = (N_used * v.T) > 0 ? (QL_million / (N_used * v.T)) : 0;
  const NSLD_year = N_used > 0 ? (v.GTT / N_used * 12 / v.T) : 0;
  const N_reg = 0.034 * v.GTT + 16.96;

  let csv = '\uFEFF';
  csv += 'TÍNH PHỔ THÔNG - CHI PHÍ NHÂN SỰ DỰ ÁN\n';
  csv += 'Theo Báo cáo Định biên Nhân sự 2026\n\n';
  csv += 'THAM SỐ ĐẦU VÀO\n';
  csv += 'Loại hình,'+d.label+'\n';
  csv += 'GTT (Giá trị gói thầu) tỷ VND,'+v.GTT+'\n';
  csv += 'T (Tiến độ) tháng,'+v.T+'\n';
  csv += 'L (Lương TB) tr/ng/tháng,'+v.L+'\n';
  csv += 'R (Tỷ lệ %) ,'+v.R+'%\n';
  csv += 'N (Số NS - '+(v.N?'user':'auto')+'),'+N_used+'\n';
  csv += 'Hệ số biến động thời gian,×'+v.timeCoef.toFixed(2)+'\n\n';
  csv += 'KẾT QUẢ\n';
  csv += '[1] QL chuẩn = GTT × R,'+QL_base_billion.toFixed(2)+' tỷ\n';
  csv += '[2] N từ QL/L/T,'+N_auto+' người\n';
  csv += '[3] L back-calc,'+L_check.toFixed(2)+' tr\n';
  csv += '[4] NSLĐ năm,'+NSLD_year.toFixed(2)+' tỷ/ng/năm\n';
  csv += '[5] N hồi quy,'+N_reg.toFixed(1)+' người\n';
  csv += 'QL hiệu chỉnh thời gian,'+QL_adj_billion.toFixed(2)+' tỷ\n';

  const blob = new Blob([csv], { type:'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'TinhPhoThong_NhanSu.csv';
  a.click();
  URL.revokeObjectURL(url);
}

// ===== SUMMARY =====
function calcTotals(){
  let totalPeople = 0, totalCost = 0;
  const byNgach = { QLCC: 0, QL: 0, CV: 0, NV: 0 };
  const lines = [];

  STAFF_DATA.forEach(s => {
    const st = staffState[s.code];
    const qty = st.qty || 0;
    const months = st.months || 0;
    if (qty === 0 || months === 0) return;
    const perMonth = s.hard + s.welfare;
    const lineTotal = qty * perMonth * months;
    totalPeople += qty;
    totalCost += lineTotal;
    // Dùng phân loại theo CHỨC DANH (getStaffGroup) thay vì ngạch lương
    const ngachGroup = getStaffGroup(s.code, s.ngach);
    byNgach[ngachGroup] = (byNgach[ngachGroup] || 0) + lineTotal;
    lines.push({ ...s, qty, months, perMonth, lineTotal, group: ngachGroup });
  });

  return { totalPeople, totalCost, byNgach, lines };
}

function getStatusInfo(actualPct, ccmPct){
  // Xanh: thấp hơn CCM (tiết kiệm) | Vàng: ±10% | Đỏ: vượt > 10%
  const diff = actualPct - ccmPct;
  if (diff < -0.3) return { status:'under', color:'#0a9396', label:'Thấp hơn CCM', cls:'alert-info' };
  if (Math.abs(diff) <= 0.3) return { status:'on', color:'#0a9396', label:'Đạt mục tiêu', cls:'alert-success' };
  if (diff <= 0.6) return { status:'over', color:'#bb6016', label:'Vượt nhẹ CCM', cls:'alert-warning' };
  return { status:'far-over', color:'#e94560', label:'Vượt nhiều CCM', cls:'alert-danger' };
}

function renderSummary(){
  const p = getProjectInputs();
  const ccm = getCurrentCCM();
  const totals = calcTotals();
  const projectValueVND = p.value * 1e9;
  const actualPct = projectValueVND > 0 ? (totals.totalCost / projectValueVND) * 100 : 0;
  const targetBudget = projectValueVND * ccm.rate / 100;
  const variance = totals.totalCost - targetBudget;
  const status = getStatusInfo(actualPct, ccm.rate);

  // Alert
  let alertHtml = '<div class="alert '+status.cls+'">';
  alertHtml += '<b>📊 KẾT QUẢ:</b> ' + status.label + ' — ';
  alertHtml += 'Quỹ lương thực tế <b>' + fmtPct(actualPct) + '</b> ';
  alertHtml += '(' + (actualPct > ccm.rate ? 'cao hơn' : 'thấp hơn') + ' CCM đề xuất <b>' + fmtPct(ccm.rate) + '</b> ';
  alertHtml += (variance >= 0 ? '+' : '') + fmtBn(variance) + ')';
  alertHtml += '</div>';
  document.getElementById('summaryAlert').innerHTML = alertHtml;

  // Cards
  const adjBadge = ccm.applies && Math.abs(ccm.coef - 1) > 0.001 ? ' (×'+ccm.coef.toFixed(2)+')' : '';
  const cards = [
    { l:'Quỹ lương Thực tế', v: fmtBn(totals.totalCost), s: fmtMoney(totals.totalCost), c:'#e94560' },
    { l:'Ngân sách CCM'+adjBadge, v: fmtBn(targetBudget), s: fmtPct(ccm.rate)+(adjBadge?' (gốc '+fmtPct(ccm.baseRate)+')':''), c:'#0a9396' },
    { l:'Chênh lệch', v: (variance >= 0 ? '+' : '') + fmtBn(variance), s: (variance >= 0 ? 'Vượt' : 'Dưới') + ' ngân sách', c: status.color },
    { l:'% Thực tế / Doanh thu', v: fmtPct(actualPct), s:'CCM: '+fmtPct(ccm.rate), c: status.color },
    { l:'Tổng nhân sự', v: totals.totalPeople + ' người', s:'Trên ' + p.duration + ' tháng', c:'#0f3460' },
    { l:'Chi phí TB/người/tháng', v: totals.totalPeople > 0 && p.duration > 0 ? fmt(totals.totalCost / totals.totalPeople / p.duration) : '0', s:'VND', c:'#7b2cbf' },
  ];
  document.getElementById('summaryCards').innerHTML = cards.map(c =>
    '<div class="card" style="border-left:4px solid '+c.c+'">'
    + '<div class="card-val" style="color:'+c.c+';font-size:18px">'+c.v+'</div>'
    + '<div class="card-label">'+c.l+'</div>'
    + '<div class="card-sub">'+c.s+'</div></div>'
  ).join('');

  // Project info
  const adj = getAdjustmentInfo();
  let infoHtml = '<div class="info-row"><span>Tên dự án</span><b>'+p.name+'</b></div>' +
    '<div class="info-row"><span>Chủ đầu tư</span><b>'+p.owner+'</b></div>' +
    '<div class="info-row"><span>Loại hình</span><b>'+TYPE_LABELS[p.type]+'</b></div>' +
    '<div class="info-row"><span>Giá trị Doanh thu</span><b>'+p.value+' tỷ VND ('+sizeLabel(ccm.bucket)+')</b></div>' +
    '<div class="info-row"><span>Tiến độ</span><b>'+p.duration+' tháng</b></div>' +
    '<div class="info-row"><span>Miền chính</span><b>'+(p.defaultRegion === 'CM' ? 'Cùng miền' : 'Trái miền')+'</b></div>';
  if (adj.applies) {
    infoHtml += '<div class="info-row"><span>Phạm vi công việc (Scope)</span><b>'+SCOPE_LABELS[adj.scopeKey]+' (×'+adj.scopeCoef.toFixed(2)+')</b></div>';
    infoHtml += '<div class="info-row"><span>Mức chồng chéo (Overlap)</span><b>'+OVERLAP_LABELS[adj.overlapKey]+' (×'+adj.overlapCoef.toFixed(2)+')</b></div>';
    infoHtml += '<div class="info-row"><span>% CCM Gốc</span><b style="color:#0f3460">'+fmtPct(ccm.baseRate)+'</b></div>';
    infoHtml += '<div class="info-row"><span>Hệ số tổng điều chỉnh</span><b style="color:#854d0e">×'+adj.totalCoef.toFixed(2)+'</b></div>';
    infoHtml += '<div class="info-row"><span>% CCM Áp dụng (Hiệu chỉnh)</span><b style="color:#e94560;font-size:14px">'+fmtPct(ccm.rate)+'</b></div>';
  } else {
    infoHtml += '<div class="info-row"><span>% CCM áp dụng</span><b style="color:#e94560">'+fmtPct(ccm.rate)+'</b></div>';
  }
  document.getElementById('projectInfo').innerHTML = infoHtml;

  // Comparison
  const targetBudgetBase = projectValueVND * ccm.baseRate / 100;
  let cmpHtml = '<table style="width:100%;border-collapse:collapse">';
  cmpHtml += '<tr style="background:#f5f5f5"><th style="padding:8px;text-align:left;font-size:12px">Chỉ tiêu</th><th style="padding:8px;text-align:right;font-size:12px">Giá trị (VND)</th><th style="padding:8px;text-align:right;font-size:12px">% so DT</th></tr>';
  cmpHtml += '<tr><td style="padding:8px;border-bottom:1px solid #eee">Doanh thu Dự án</td><td style="padding:8px;text-align:right;border-bottom:1px solid #eee;font-weight:700">'+fmt(projectValueVND)+'</td><td style="padding:8px;text-align:right;border-bottom:1px solid #eee">100.00%</td></tr>';
  if (adj.applies && Math.abs(adj.totalCoef - 1) > 0.001) {
    cmpHtml += '<tr><td style="padding:8px;border-bottom:1px solid #eee;color:#888">Ngân sách CCM Gốc (chưa hiệu chỉnh)</td><td style="padding:8px;text-align:right;border-bottom:1px solid #eee;color:#888">'+fmt(targetBudgetBase)+'</td><td style="padding:8px;text-align:right;border-bottom:1px solid #eee;color:#888">'+fmtPct(ccm.baseRate)+'</td></tr>';
  }
  cmpHtml += '<tr><td style="padding:8px;border-bottom:1px solid #eee;color:#0a9396"><b>Ngân sách CCM Áp dụng</b>'+(adj.applies && Math.abs(adj.totalCoef - 1) > 0.001 ? ' (×'+adj.totalCoef.toFixed(2)+')' : '')+'</td><td style="padding:8px;text-align:right;border-bottom:1px solid #eee;font-weight:700;color:#0a9396">'+fmt(targetBudget)+'</td><td style="padding:8px;text-align:right;border-bottom:1px solid #eee;color:#0a9396;font-weight:700">'+fmtPct(ccm.rate)+'</td></tr>';
  cmpHtml += '<tr><td style="padding:8px;border-bottom:1px solid #eee;color:#e94560"><b>Quỹ lương Thực tế</b></td><td style="padding:8px;text-align:right;border-bottom:1px solid #eee;font-weight:700;color:#e94560">'+fmt(totals.totalCost)+'</td><td style="padding:8px;text-align:right;border-bottom:1px solid #eee;color:#e94560;font-weight:700">'+fmtPct(actualPct)+'</td></tr>';
  cmpHtml += '<tr style="background:'+(variance>=0?'#fee2e2':'#dcfce7')+'"><td style="padding:8px;font-weight:800">Chênh lệch (Thực tế vs CCM Áp dụng)</td><td style="padding:8px;text-align:right;font-weight:800">'+(variance>=0?'+':'')+fmt(variance)+'</td><td style="padding:8px;text-align:right;font-weight:800">'+(variance>=0?'+':'')+(actualPct-ccm.rate).toFixed(2)+'%</td></tr>';
  cmpHtml += '</table>';
  document.getElementById('comparisonBox').innerHTML = cmpHtml;

  // Distribution
  const groupColors = { QLCC:'#5b21b6', QL:'#166534', CV:'#854d0e', NV:'#6b21a8' };
  const groupCounts = { QLCC:0, QL:0, CV:0, NV:0 };
  const groupCodes  = { QLCC:[], QL:[], CV:[], NV:[] };
  totals.lines.forEach(l => {
    groupCounts[l.group] = (groupCounts[l.group] || 0) + l.qty;
    if (groupCodes[l.group]) groupCodes[l.group].push(l.code + '×' + l.qty);
  });

  let distHtml = '<table style="width:100%;border-collapse:collapse">';
  distHtml += '<tr style="background:#f5f5f5"><th style="padding:8px;text-align:left;font-size:12px">Nhóm</th><th style="padding:8px;text-align:right;font-size:12px">Số người</th><th style="padding:8px;text-align:right;font-size:12px">Quỹ lương</th><th style="padding:8px;text-align:left;font-size:12px;width:30%">% Cơ cấu Quỹ</th><th style="padding:8px;text-align:left;font-size:12px">Chức danh</th></tr>';
  const ngachNames = {
    QLCC:'QLCC — Quản lý Cấp cao (GDK, GDDA)',
    QL:  'QL — Quản lý Công trường (CHT)',
    CV:  'CV — Chuyên viên (CHP, GSC, GS1, GSAT1)',
    NV:  'NV — Nhân viên (GS2, GSAT2, TKY, TKHO)',
  };
  const bgColors = { QLCC:'#ede9fe', QL:'#dcfce7', CV:'#fef3c7', NV:'#f3e8ff' };
  ['QLCC','QL','CV','NV'].forEach(g => {
    const v = totals.byNgach[g] || 0;
    const pct = totals.totalCost > 0 ? (v / totals.totalCost) * 100 : 0;
    const cnt = groupCounts[g] || 0;
    const codes = groupCodes[g] && groupCodes[g].length > 0 ? groupCodes[g].join(', ') : '<i style="color:#bbb">—</i>';
    distHtml += '<tr style="background:'+(cnt>0?bgColors[g]:'#fff')+'">';
    distHtml += '<td style="padding:8px;border-bottom:1px solid #eee;font-weight:700;color:'+groupColors[g]+'">'+ngachNames[g]+'</td>';
    distHtml += '<td style="padding:8px;text-align:right;border-bottom:1px solid #eee;font-weight:700;color:'+groupColors[g]+'">'+cnt+' người</td>';
    distHtml += '<td style="padding:8px;text-align:right;border-bottom:1px solid #eee;font-weight:700">'+fmt(v)+'</td>';
    distHtml += '<td style="padding:8px;border-bottom:1px solid #eee">';
    distHtml += '<span class="chart-bar" style="width:'+Math.max(2,pct*2.5)+'px;background:linear-gradient(90deg,'+groupColors[g]+',#0f3460)"></span> <b>'+pct.toFixed(1)+'%</b>';
    distHtml += '</td>';
    distHtml += '<td style="padding:8px;border-bottom:1px solid #eee;font-size:11px;color:#555">'+codes+'</td>';
    distHtml += '</tr>';
