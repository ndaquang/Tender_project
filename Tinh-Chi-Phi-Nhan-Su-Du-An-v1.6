// ===== DETAILED REPORT =====
function renderDetailedReport(){
  const p = getProjectInputs();
  const ccm = getCurrentCCM();
  const totals = calcTotals();
  const projectValueVND = p.value * 1e9;
  const actualPct = projectValueVND > 0 ? (totals.totalCost / projectValueVND) * 100 : 0;

  let html = '<div style="margin-bottom:14px;padding:10px;background:#f8f9fc;border-radius:8px;font-size:12px;line-height:1.8">';
  html += '<b>Dự án:</b> '+p.name+' | <b>Loại:</b> '+TYPE_LABELS[p.type]+' | ';
  html += '<b>DT:</b> '+p.value+' tỷ | <b>Tiến độ:</b> '+p.duration+' tháng<br>';
  if (ccm.applies && Math.abs(ccm.coef - 1) > 0.001) {
    const adj = getAdjustmentInfo();
    html += '<b>Scope:</b> '+SCOPE_LABELS[adj.scopeKey]+' (×'+adj.scopeCoef.toFixed(2)+') | <b>Overlap:</b> '+OVERLAP_LABELS[adj.overlapKey]+' (×'+adj.overlapCoef.toFixed(2)+') | <b>Hệ số tổng:</b> ×'+adj.totalCoef.toFixed(2)+'<br>';
    html += '<b>% CCM Gốc:</b> '+fmtPct(ccm.baseRate)+' → <b>% CCM Hiệu chỉnh:</b> <span style="color:#e94560;font-weight:700">'+fmtPct(ccm.rate)+'</span> | <b>% Thực tế:</b> <span style="color:#0a9396;font-weight:700">'+fmtPct(actualPct)+'</span>';
  } else {
    html += '<b>% CCM:</b> '+fmtPct(ccm.rate)+' | <b>% Thực tế:</b> '+fmtPct(actualPct);
  }
  html += '</div>';

  if (totals.lines.length === 0) {
    html += '<div style="text-align:center;padding:40px;color:#999"><div style="font-size:32px;margin-bottom:8px">📋</div><div>Chưa có nhân sự được nhập. Quay lại tab <b>Cơ cấu Nhân sự</b> để thêm.</div></div>';
    document.getElementById('detailedReport').innerHTML = html;
    return;
  }

  html += '<div class="tbl-wrap"><table>';
  html += '<thead><tr>';
  ['STT','Code','Chức danh','Nhóm','Miền','Lương cứng','Phúc lợi','Tổng/tháng','SL','Số tháng','Thành tiền','% / Quỹ'].forEach(h =>
    html += '<th style="font-size:11px">'+h+'</th>'
  );
  html += '</tr></thead><tbody>';

  totals.lines.forEach((l, i) => {
    const pct = totals.totalCost > 0 ? (l.lineTotal / totals.totalCost) * 100 : 0;
    html += '<tr>';
    html += '<td class="tc">'+(i+1)+'</td>';
    html += '<td style="font-family:monospace;font-size:11px;color:#0f3460;font-weight:600">'+l.code+'</td>';
    html += '<td style="font-weight:500">'+l.title+'</td>';
    html += '<td class="tc"><span class="badge '+getGroupBadgeClass(l.group)+'" style="font-weight:800">'+l.group+'</span></td>';
    html += '<td class="tc">'+(l.region || '—')+'</td>';
    html += '<td class="num-r">'+fmt(l.hard)+'</td>';
    html += '<td class="num-r" style="color:#888">'+fmt(l.welfare)+'</td>';
    html += '<td class="num-r" style="font-weight:700">'+fmt(l.perMonth)+'</td>';
    html += '<td class="tc" style="font-weight:700;color:#e94560">'+l.qty+'</td>';
    html += '<td class="tc">'+l.months+'</td>';
    html += '<td class="num-r" style="font-weight:800;color:#0f3460">'+fmt(l.lineTotal)+'</td>';
    html += '<td class="num-r" style="color:#0a9396;font-weight:700">'+pct.toFixed(1)+'%</td>';
    html += '</tr>';
  });

  html += '<tr class="row-total">';
  html += '<td colspan="8" class="num-r">TỔNG CỘNG</td>';
  html += '<td class="tc">'+totals.totalPeople+'</td>';
  html += '<td class="tc">—</td>';
  html += '<td class="num-r">'+fmt(totals.totalCost)+'</td>';
  html += '<td class="tc">100.0%</td>';
  html += '</tr>';

  html += '</tbody></table></div>';

  document.getElementById('detailedReport').innerHTML = html;
}

// ===== EXPORT CSV =====
function exportToCSV(){
  const p = getProjectInputs();
  const ccm = getCurrentCCM();
  const totals = calcTotals();
  const projectValueVND = p.value * 1e9;
  const actualPct = projectValueVND > 0 ? (totals.totalCost / projectValueVND) * 100 : 0;

  let csv = '\uFEFF'; // BOM for UTF-8 Excel
  csv += 'BÁO CÁO CHI PHÍ NHÂN SỰ DỰ ÁN\n';
  csv += 'Tên dự án,'+p.name+'\n';
  csv += 'Chủ đầu tư,'+p.owner+'\n';
  csv += 'Loại hình,'+TYPE_LABELS[p.type]+'\n';
  csv += 'Giá trị DA (tỷ VND),'+p.value+'\n';
  csv += 'Tiến độ (tháng),'+p.duration+'\n';
  csv += '% CCM Gốc,'+ccm.baseRate.toFixed(2)+'%\n';
  if (ccm.applies && Math.abs(ccm.coef - 1) > 0.001) {
    const adj = getAdjustmentInfo();
    csv += 'Scope,"'+SCOPE_LABELS[adj.scopeKey]+' (x'+adj.scopeCoef.toFixed(2)+')"\n';
    csv += 'Overlap,"'+OVERLAP_LABELS[adj.overlapKey]+' (x'+adj.overlapCoef.toFixed(2)+')"\n';
    csv += 'Hệ số tổng,x'+adj.totalCoef.toFixed(2)+'\n';
    csv += '% CCM Hiệu chỉnh (Áp dụng),'+ccm.rate.toFixed(2)+'%\n';
  } else {
    csv += '% CCM Áp dụng,'+ccm.rate.toFixed(2)+'%\n';
  }
  csv += '% Thực tế,'+actualPct.toFixed(2)+'%\n';
  csv += '\n';
  csv += 'STT,Code,Chức danh,Nhóm,Miền,Lương cứng,Phúc lợi,Tổng/tháng,Số lượng,Số tháng,Thành tiền\n';

  totals.lines.forEach((l, i) => {
    csv += [
      i+1,
      l.code,
      '"'+l.title+'"',
      l.group,
      l.region || '',
      l.hard,
      l.welfare,
      l.perMonth,
      l.qty,
      l.months,
      l.lineTotal
    ].join(',') + '\n';
  });

  csv += ',,,,,,,,TỔNG,'+totals.totalPeople+','+totals.totalCost+'\n';

  const blob = new Blob([csv], { type:'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'ChiPhiNhanSu_'+(p.name||'DuAn').replace(/[^a-zA-Z0-9]/g,'_')+'.csv';
  a.click();
  URL.revokeObjectURL(url);
}

