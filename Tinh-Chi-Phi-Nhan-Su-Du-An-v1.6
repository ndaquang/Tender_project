function renderISORoles(){
  let html = '<div class="iso-role-grid">';
  ISO_ROLES.forEach(r => {
    const activeCodes = r.codes.filter(c => staffState[c] && staffState[c].qty > 0);
    const totalQty = activeCodes.reduce((sum, c) => sum + (staffState[c].qty || 0), 0);
    const isExternal = r.external;

    html += '<div class="iso-role-card"'+(isExternal?' style="opacity:.6;border-left-color:#9ca3af"':'')+'>';
    html += '<div class="role-title">'+r.role+'<br><span style="font-size:10px;color:#7b2cbf;font-weight:600">'+r.vn+'</span></div>';
    html += '<div class="role-desc">'+r.desc+'</div>';

    if (isExternal) {
      html += '<div style="font-size:11px;color:#dc2626;font-weight:700">⚠️ '+r.note+'</div>';
    } else {
      html += '<div class="role-codes"><b>Vị trí áp dụng:</b><br>';
      if (activeCodes.length > 0) {
        html += '<span style="color:#0a9396;font-weight:700">✅ Đang có: '+totalQty+' người</span> ('+activeCodes.join(', ')+')';
      } else {
        html += '<span style="color:#9ca3af">— Chưa có nhân sự nào —</span><br>';
        html += '<span style="font-size:10px;color:#6b7280">Code khả dụng: '+r.codes.slice(0,3).join(', ')+(r.codes.length>3?'...':'')+'</span>';
      }
      html += '</div>';
      html += '<div style="font-size:10px;color:#7b2cbf;margin-top:6px;font-style:italic">💡 '+r.note+'</div>';
    }
    html += '</div>';
  });
  html += '</div>';

  // Summary
  const totals = calcTotals();
  html += '<div style="margin-top:14px;padding:10px;background:#f5f3ff;border-radius:8px;font-size:12px;line-height:1.7;border:1px solid #ddd6fe">';
  html += '<b style="color:#6b21a8">📌 Đánh giá Cơ cấu Tổ chức theo ISO 21502:</b><br>';

  const hasPM = ISO_ROLES[2].codes.some(c => staffState[c] && staffState[c].qty > 0);
  const hasQA = ISO_ROLES[5].codes.some(c => staffState[c] && staffState[c].qty > 0);
  const hasPSO = ISO_ROLES[6].codes.some(c => staffState[c] && staffState[c].qty > 0);
  const hasTL = ISO_ROLES[3].codes.some(c => staffState[c] && staffState[c].qty > 0);

  html += (hasPM?'✅':'❌')+' <b>Project Manager</b> — Single Point of Accountability '+(hasPM?'(có)':'(THIẾU)')+'<br>';
  html += (hasTL?'✅':'❌')+' <b>Team Lead</b> — Quản lý mảng chuyên môn '+(hasTL?'(có)':'(THIẾU)')+'<br>';
  html += (hasQA?'✅':'⚠️')+' <b>Quality Assurance (GSAT)</b> — Đảm bảo CL độc lập '+(hasQA?'(có)':'(thiếu — bắt buộc cho dự án XD)')+'<br>';
  html += (hasPSO?'✅':'⚠️')+' <b>Project Support Office</b> — PMO hành chính '+(hasPSO?'(có)':'(nên có)')+'<br>';
  html += '</div>';

  document.getElementById('iso21502Box').innerHTML = html;
}

