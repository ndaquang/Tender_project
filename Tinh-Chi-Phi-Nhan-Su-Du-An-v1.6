function getSizeBucket(valueBn){
  if (valueBn < 100) return 'small';
  if (valueBn <= 250) return 'medium';
  return 'large';
}
function sizeLabel(b){
  return { small:'< 100 tỷ', medium:'100–250 tỷ', large:'> 250 tỷ' }[b];
}

function getCurrentCCM(){
  const p = getProjectInputs();
  const bucket = getSizeBucket(p.value);
  const baseRate = CCM_RATES[p.type][bucket];
  // Lấy hệ số nếu có
  let coef = 1.0, applies = false;
  const coefEl = document.getElementById('totalCoef');
  if (coefEl) {
    const adj = getAdjustmentInfo();
    applies = adj.applies;
    coef = applies ? adj.totalCoef : 1.0;
  }
  const rate = baseRate * coef;
  return { rate, baseRate, coef, applies, bucket, type: p.type };
}

function getNgachClass(ngach){
  if (ngach && ngach.startsWith('QL')) return 'badge-ql';
  if (ngach && ngach.startsWith('CV')) return 'badge-cv';
  if (ngach && ngach.startsWith('NV')) return 'badge-nv';
