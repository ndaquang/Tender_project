// Resolve code thực tế từ item config + quy mô + miền
function resolveCode(item, bucket, region){
  // levels: cấp khả dụng của vị trí này
  // bucket → cấp tương ứng (small=3, medium=2, large=1)
  const preferLvl = { small:'3', medium:'2', large:'1' }[bucket];
  // Tìm cấp gần nhất với preferLvl trong levels của item
  let useLvl = preferLvl;
  if (item.levels && item.levels.length > 0 && !item.levels.includes(preferLvl)) {
    // Lấy cấp đầu tiên trong levels
    useLvl = item.levels[0];
  }
  let code = item.prefix + useLvl;
  // Thử với region
  const withRegion = STAFF_DATA.find(s => s.code === code + region);
  if (withRegion) return code + region;
  // Thử không region
  const noRegion = STAFF_DATA.find(s => s.code === code);
  if (noRegion) return code;
  // Fallback: tìm code khác có cùng prefix
  const anyMatch = STAFF_DATA.find(s => s.code.startsWith(item.prefix));
  return anyMatch ? anyMatch.code : null;
}

// Phân phối tổng `total` vào các item theo `share`, ưu tiên item mandatory có tối thiểu 1 nếu total cho phép
function distributeWithMandatory(total, items){
  if (total <= 0) return items.map(() => 0);

  // Đếm item bắt buộc
  const mandatoryCount = items.filter(it => it.mandatory).length;

  // Nếu total < mandatoryCount: chỉ phân 1 cho mỗi mandatory theo thứ tự, không đủ thì bỏ
  if (total <= mandatoryCount) {
    const result = items.map(() => 0);
    let assigned = 0;
    items.forEach((it, i) => {
      if (it.mandatory && assigned < total) { result[i] = 1; assigned++; }
    });
    return result;
  }

  // Đảm bảo mỗi mandatory có ít nhất 1
  const result = items.map(it => it.mandatory ? 1 : 0);
  const remaining = total - mandatoryCount;

  // Phân phần còn lại theo share
  const sumShare = items.reduce((a, it) => a + it.share, 0);
  if (sumShare === 0 || remaining === 0) {
    // Đẩy nốt phần thừa vào item có share lớn nhất
    if (remaining > 0) {
      const maxIdx = items.reduce((mi, it, i) => it.share > items[mi].share ? i : mi, 0);
      result[maxIdx] += remaining;
    }
    return result;
  }
  const raw = items.map(it => remaining * it.share / sumShare);
  let extra = raw.map(v => Math.floor(v));
  let used = extra.reduce((a, b) => a + b, 0);
  let leftover = remaining - used;
  const fracs = raw.map((v, i) => ({ i, frac: v - Math.floor(v) }));
  fracs.sort((a, b) => b.frac - a.frac);
  for (let k = 0; k < leftover; k++) extra[fracs[k % fracs.length].i]++;

  return result.map((v, i) => v + extra[i]);
}

function renderRuleCompare(total, bucket, region){
  const rules = [
    { name:'1:4:5', desc:'Agile / Quality-focused' },
    { name:'1:3:6', desc:'Traditional / Waterfall' },
    { name:'1:2:7', desc:'Heavy-execution' },
    { name:'1:5:4', desc:'Quality-heavy' },
  ];
  const avg = computeAvgSalaryByGroup(bucket, region);
  const p = getProjectInputs();
  const dur = p.duration;
  const projectVND = p.value * 1e9;
  const currentRule = document.getElementById('spanRule').value;

  let html = '<div class="tbl-wrap" style="margin-bottom:0"><table class="rule-compare-tbl"><thead><tr>';
  html += '<th style="text-align:left">Quy tắc</th><th>QL</th><th>CV</th><th>NV</th><th>Quỹ lương</th><th>% / DT</th><th>% QL quỹ</th><th>% CV quỹ</th><th>% NV quỹ</th>';
  html += '</tr></thead><tbody>';

  rules.forEach(r => {
    const ruleObj = parseRule(r.name);
    const a = allocateByRule(total, ruleObj);
    const cQL = a.ql * avg.QL * dur;
    const cCV = a.cv * avg.CV * dur;
    const cNV = a.nv * avg.NV * dur;
    const cTot = cQL + cCV + cNV;
    const pTot = projectVND>0 ? (cTot/projectVND*100) : 0;
    const isActive = (r.name === currentRule);
    html += '<tr'+(isActive?' class="active-rule"':'')+'>';
    html += '<td class="rule-name">'+r.name+(isActive?' ⭐':'')+'<br><span style="font-size:10px;color:#666;font-weight:400">'+r.desc+'</span></td>';
    html += '<td>'+a.ql+'</td><td>'+a.cv+'</td><td>'+a.nv+'</td>';
    html += '<td style="font-weight:700;color:#e94560">'+fmtBn(cTot)+'</td>';
    html += '<td style="font-weight:700;color:#0a9396">'+pTot.toFixed(2)+'%</td>';
    html += '<td>'+(cTot>0?(cQL/cTot*100).toFixed(1):'0')+'%</td>';
    html += '<td>'+(cTot>0?(cCV/cTot*100).toFixed(1):'0')+'%</td>';
    html += '<td>'+(cTot>0?(cNV/cTot*100).toFixed(1):'0')+'%</td>';
    html += '</tr>';
  });
  html += '</tbody></table></div>';
  html += '<div class="notice" style="margin-top:8px">💡 Mặc dù số lượng QL ít nhất, nhưng do lương cao nên QL thường chiếm 30-45% quỹ lương. Quy tắc 1:5:4 (Quality-heavy) sẽ tăng % quỹ CV.</div>';
  document.getElementById('ruleCompareBox').innerHTML = html;
}

function applyAutoAllocation(){
  const total = parseInt(document.getElementById('totalStaffCount').value) || 0;
  if (total <= 0) {
    alert('⚠️ Tổng số nhân sự phải > 0');
    return;
  }
  if (!confirm('Hệ thống sẽ ghi đè Cơ cấu Nhân sự hiện tại theo phân bổ này. Tiếp tục?')) return;

  const rule = getCurrentRule();
  const alloc = allocateByRule(total, rule);
  const p = getProjectInputs();
  const bucket = getSizeBucket(p.value);
  const region = p.defaultRegion;

  // Reset
  STAFF_DATA.forEach(s => { staffState[s.code] = { qty: 0, months: 0 }; });

  // CÙNG cấu hình với renderNgachDetail
  const groups = {
    QL: [
      { prefix:'CHT', share: 0.70, mPct: 1.00, mandatory:true,  levels:['1','2','3'] },
      { prefix:'GDDA',share: 0.30, mPct: 0.30, mandatory:false, levels:['1','2','3'], partTime:true },
    ],
    CV: [
      { prefix:'CHP', share: 0.35, mPct: 1.00, mandatory:false, levels:['1','2','3'] },
      { prefix:'GSAT',share: 0.15, mPct: 1.00, mandatory:true,  levels:['1'] },
      { prefix:'GSC', share: 0.20, mPct: 1.00, mandatory:false, levels:['1','2'] },
      { prefix:'GS1', share: 0.30, mPct: 1.00, mandatory:false, levels:['1'] },
    ],
    NV: [
      { prefix:'GS2', share: 0.50, mPct: 1.00, mandatory:false, levels:['2'] },
      { prefix:'GSAT',share: 0.15, mPct: 1.00, mandatory:false, levels:['2'] },
      { prefix:'TKY', share: 0.20, mPct: 1.00, mandatory:false, levels:[''] },
      { prefix:'TKHO',share: 0.15, mPct: 1.00, mandatory:false, levels:[''] },
    ],
  };
  const counts = { QL: alloc.ql, CV: alloc.cv, NV: alloc.nv };

  let appliedSummary = [];
  Object.keys(groups).forEach(grp => {
    const totalNgach = counts[grp];
    const items = groups[grp];
    const alloced = distributeWithMandatory(totalNgach, items);

    items.forEach((it, idx) => {
      const n = alloced[idx];
      if (n === 0) return;
      const code = resolveCode(it, bucket, region);
      if (code && staffState[code] !== undefined) {
        staffState[code].qty = n;
        staffState[code].months = Math.round(p.duration * it.mPct * 10) / 10;
        appliedSummary.push(grp + ' · ' + code + ': ' + n + ' người × ' + staffState[code].months + ' tháng');
      }
    });
  });

  // Re-render bảng nhân sự
  renderStaffTable();

  alert('✅ Đã áp dụng phân bổ '+document.getElementById('spanRule').value+': '+alloc.ql+' QL + '+alloc.cv+' CV + '+alloc.nv+' NV = '+total+' người.\n\n📋 Chi tiết áp dụng:\n' + appliedSummary.join('\n') + '\n\nChuyển sang tab Cơ cấu Nhân sự để xem chi tiết.');
  switchTab('staff');
}

