  { id:'quick', icon:'⚡', label:'Tính Phổ Thông', desc:'QL=GTT×R → N=QL/(L×T) + hệ số thời gian' },
  { id:'auto',  icon:'🎯', label:'Phân bổ Tự động',desc:'N người → QL:CV:NV theo tỷ lệ 1:N:M' },
  { id:'staff', icon:'👥', label:'Cơ cấu Nhân sự', desc:'Chi tiết 34 chức danh, số lượng, tháng' },
  { id:'pmbok', icon:'📐', label:'PMBOK / ISO',     desc:'Process Groups, RACI, ISO 21502 roles' },
  { id:'summary',icon:'📊',label:'Tổng hợp',        desc:'So sánh QL thực tế vs CCM đề xuất' },
  { id:'report', icon:'📈',label:'Báo cáo',          desc:'Chi tiết + Xuất CSV' },
];

function renderFlowBar(activeId){
  const bar = document.getElementById('flowBar');
  if (!bar) return;
  bar.innerHTML = TAB_FLOWS.map((t, i) => {
    const isActive = t.id === activeId;
    const bg = isActive ? '#16213e' : '#f8f9fc';
    const color = isActive ? '#fff' : '#555';
    const arrow = i < TAB_FLOWS.length - 1
      ? `<div style="background:#e8e8ee;color:#aaa;padding:10px 4px;font-size:14px;display:flex;align-items:center">›</div>`
      : '';
    return `<div onclick="switchTab('${t.id}')" style="background:${bg};color:${color};padding:8px 10px;cursor:pointer;min-width:80px;text-align:center;line-height:1.4;flex:1;transition:background .15s" title="${t.desc}">
      <div style="font-size:16px">${t.icon}</div>
      <div style="font-weight:${isActive?'700':'500'};font-size:10px;margin-top:2px">${t.label}</div>
      ${isActive ? `<div style="font-size:9px;opacity:.75;margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${t.desc}</div>` : ''}
    </div>${arrow}`;
  }).join('');
}

// ===== TAB SWITCH =====
function switchTab(name){
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  // Highlight tab button
  const tabs = ['input','quick','auto','staff','pmbok','summary','report'];
  document.querySelectorAll('.tab-btn').forEach((b,i) => {
    if (tabs[i] === name) b.classList.add('active');
  });
  // Render flow bar
  renderFlowBar(name);
  // Khi vào tab → sync state → UI (cập nhật tất cả mirror inputs)
  stateToUI();
  // Render từng tab
  if (name === 'summary') renderSummary();
  if (name === 'report')  renderDetailedReport();
  if (name === 'staff')   renderStaffTable();
  if (name === 'auto')    updateAutoAllocation();
  if (name === 'pmbok')   renderPMBOK();
  if (name === 'quick')   updateQuickCalc();
}

// ===== RENDER CCM TABLE =====
function renderCCMTable(){
  const p = getProjectInputs();
  const currentBucket = getSizeBucket(p.value);
  const tbody = document.getElementById('ccmTableBody');
  const types = ['NX','CT','TT'];
  const buckets = ['small','medium','large'];
  let html = '';
  types.forEach(t => {
    html += '<tr>';
    html += '<td class="label">' + TYPE_LABELS[t] + '</td>';
    buckets.forEach(b => {
      const rate = CCM_RATES[t][b];
      const isCurrent = (t === p.type && b === currentBucket);
      html += '<td class="pct'+(isCurrent?' pct-highlight':'')+'" title="Click để chỉnh">'
        + '<input type="number" step="0.01" value="'+rate.toFixed(2)+'" style="width:60px;border:none;background:transparent;text-align:center;font-weight:'+(isCurrent?'800':'700')+';color:inherit;font-size:13px" '
        + 'onchange="updateCCMRate(\''+t+'\',\''+b+'\',this.value)"> %'
        + '</td>';
    });
    html += '</tr>';
  });
  tbody.innerHTML = html;
}

function updateCCMRate(type, bucket, value){
  const v = parseFloat(value);
  if (!isNaN(v)) CCM_RATES[type][bucket] = v;
  updateAll();
}

// ===== SCENARIO / SCOPE / OVERLAP =====
const SCENARIO_PRESETS = {
  base:   { scope:'full',  overlap:'none',   total:1.00 },
  easy:   { scope:'full',  overlap:'light',  total:1.08 },
  medium: { scope:'th_ht', overlap:'medium', total:1.18 },
  hard:   { scope:'tho',   overlap:'high',   total:1.32 },
  finish: { scope:'ht',    overlap:'high',   total:1.45 },
  me:     { scope:'me',    overlap:'high',   total:1.55 },
};

const SCOPE_LABELS = {
  full:  'Tổng thầu (Thô + HT + M&E)',
  th_ht: 'Thô + Hoàn thiện',
  tho:   'Chỉ Thô',
  ht:    'Chỉ Hoàn thiện',
  me:    'Chỉ M&E',
};
const OVERLAP_LABELS = {
  none:   'Không chồng chéo',
  light:  'Chồng chéo nhẹ',
  medium: 'Chồng chéo TB',
  high:   'Chồng chéo cao',
};

function getCoefFromSelect(selectId){
  const sel = document.getElementById(selectId);
  const opt = sel.options[sel.selectedIndex];
  return parseFloat(opt.getAttribute('data-coef')) || 1.0;
}

function applyScenarioPreset(){
  const preset = document.getElementById('scenarioPreset').value;
  if (preset === 'custom') return;
  const cfg = SCENARIO_PRESETS[preset];
  if (!cfg) return;
  document.getElementById('scopeType').value = cfg.scope;
  document.getElementById('overlapLevel').value = cfg.overlap;
  document.getElementById('totalCoef').value = cfg.total.toFixed(2);
  updateAll();
}

function onScopeOverlapChange(){
  // Khi user đổi scope hoặc overlap → tính lại totalCoef = scope × overlap
  const scopeCoef = getCoefFromSelect('scopeType');
  const overlapCoef = getCoefFromSelect('overlapLevel');
  const total = scopeCoef * overlapCoef;
  document.getElementById('totalCoef').value = total.toFixed(2);
  document.getElementById('scenarioPreset').value = 'custom';
  updateAll();
}

function onTotalCoefChange(){
  // Khi user nhập tay totalCoef → chuyển scenario về custom
  document.getElementById('scenarioPreset').value = 'custom';
  updateAll();
}

function getAdjustmentInfo(){
  const p = getProjectInputs();
  const totalCoef = parseFloat(document.getElementById('totalCoef')?.value) || 1.0;
  const scopeKey = document.getElementById('scopeType')?.value || 'full';
  const overlapKey = document.getElementById('overlapLevel')?.value || 'none';
  const scopeCoef = getCoefFromSelect('scopeType');
  const overlapCoef = getCoefFromSelect('overlapLevel');
  // Hệ số chỉ áp dụng cho Cao tầng (CT)
  const applies = (p.type === 'CT');
  return { applies, totalCoef, scopeKey, overlapKey, scopeCoef, overlapCoef };
}

function renderAdjustmentPreview(){
  const p = getProjectInputs();
  const adj = getAdjustmentInfo();
  const bucket = getSizeBucket(p.value);
  const baseRate = CCM_RATES[p.type][bucket];
  const adjustedRate = adj.applies ? baseRate * adj.totalCoef : baseRate;

  const box = document.getElementById('adjustedRatePreview');
  if (!adj.applies) {
    box.innerHTML = '<div style="color:#92400e;font-size:12px"><b>⚠️ Hệ số không áp dụng:</b> Hiện đang chọn Loại hình <b>'+TYPE_LABELS[p.type]+'</b>. Hệ số Scope/Overlap chỉ dành cho High-Rise (cao tầng). Tỷ lệ giữ nguyên gốc: <b>'+fmtPct(baseRate)+'</b></div>';
    return;
  }

  let html = '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;align-items:center">';
  html += '<div><div style="font-size:10px;color:#888;text-transform:uppercase;letter-spacing:.5px">% CCM gốc</div><div style="font-size:18px;font-weight:800;color:#0f3460">'+fmtPct(baseRate)+'</div><div style="font-size:10px;color:#999">'+sizeLabel(bucket)+'</div></div>';
  html += '<div style="text-align:center;font-size:18px;color:#f59e0b;font-weight:800">×</div>';
  html += '<div><div style="font-size:10px;color:#888;text-transform:uppercase;letter-spacing:.5px">Hệ số Scope</div><div style="font-size:16px;font-weight:700;color:#854d0e">×'+adj.scopeCoef.toFixed(2)+'</div><div style="font-size:10px;color:#999">'+SCOPE_LABELS[adj.scopeKey]+'</div></div>';
  html += '<div><div style="font-size:10px;color:#888;text-transform:uppercase;letter-spacing:.5px">Hệ số Overlap</div><div style="font-size:16px;font-weight:700;color:#854d0e">×'+adj.overlapCoef.toFixed(2)+'</div><div style="font-size:10px;color:#999">'+OVERLAP_LABELS[adj.overlapKey]+'</div></div>';
  html += '<div style="text-align:center;font-size:18px;color:#f59e0b;font-weight:800">=</div>';
  html += '<div style="background:linear-gradient(135deg,#fef3c7,#fde68a);padding:8px 12px;border-radius:8px;border:1.5px solid #f59e0b"><div style="font-size:10px;color:#92400e;text-transform:uppercase;letter-spacing:.5px;font-weight:700">% CCM Hiệu chỉnh</div><div style="font-size:22px;font-weight:800;color:#b45309">'+fmtPct(adjustedRate)+'</div><div style="font-size:10px;color:#92400e">×'+adj.totalCoef.toFixed(2)+' so với gốc</div></div>';
  html += '</div>';
  box.innerHTML = html;
}

// ===== STAFF TABLE =====
function renderStaffTable(){
  const tbody = document.getElementById('staffTableBody');
  let html = '';

  STAFF_DATA.forEach(s => {
    const st = staffState[s.code];
    const totalPerMonth = s.hard + s.welfare;
    const lineTotal = (st.qty || 0) * totalPerMonth * (st.months || 0);
    const isActive = (st.qty > 0);
    const regionBadge = s.region ? '<span class="badge '+(s.region==='CM'?'badge-cm':'badge-tm')+'">'+s.region+'</span>' : '<span class="badge" style="background:#e5e7eb;color:#6b7280">—</span>';

    html += '<tr id="row-'+s.code+'"'+(isActive?' class="row-active"':'')+'>';
    html += '<td class="tc" style="color:#999">'+s.stt+'</td>';
    html += '<td style="font-family:monospace;font-size:11px;font-weight:600;color:#0f3460">'+s.code+'</td>';
    html += '<td style="font-weight:500">'+s.title+'</td>';
    // Chỉ còn cột NHÓM (QLCC/QL/CV/NV) — đã bỏ cột Ngạch lương
    const grp = getStaffGroup(s.code, s.ngach);
    html += '<td class="tc"><span class="badge '+getGroupBadgeClass(grp)+'" style="font-weight:800">'+grp+'</span></td>';
    html += '<td class="tc">'+regionBadge+'</td>';
    html += '<td class="num-r">'+fmt(s.hard)+'</td>';
    html += '<td class="num-r" style="color:#888">'+fmt(s.welfare)+'</td>';
    html += '<td class="num-r" style="font-weight:700;color:#0f3460">'+fmt(totalPerMonth)+'</td>';
    html += '<td class="tc"><input type="number" class="qty-input" id="qty-'+s.code+'" min="0" step="1" value="'+(st.qty||'')+'" placeholder="0" '
      + 'onfocus="this.select()" '
      + 'onchange="updateStaffQty(\''+s.code+'\',this.value)" '
      + 'oninput="updateStaffQtyLive(\''+s.code+'\',this.value)"></td>';
    html += '<td class="tc"><input type="number" class="month-input" id="month-'+s.code+'" min="0" step="0.5" value="'+(st.months||'')+'" placeholder="0" '
      + 'onfocus="this.select()" '
      + 'onchange="updateStaffMonths(\''+s.code+'\',this.value)" '
      + 'oninput="updateStaffMonthsLive(\''+s.code+'\',this.value)"></td>';
    html += '<td class="num-r" id="total-'+s.code+'" style="font-weight:800;color:'+(lineTotal>0?'#e94560':'#ccc')+'">'+(lineTotal>0?fmt(lineTotal):'—')+'</td>';
    html += '</tr>';
  });

  tbody.innerHTML = html;
  refreshStaffTotals();
}

// Cập nhật footer + cards mà KHÔNG re-render input rows (giữ focus)
function refreshStaffTotals(){
  let totalPeople = 0, totalCost = 0;
  STAFF_DATA.forEach(s => {
    const st = staffState[s.code];
    const totalPerMonth = s.hard + s.welfare;
    const lineTotal = (st.qty || 0) * totalPerMonth * (st.months || 0);
    totalPeople += (st.qty || 0);
    totalCost += lineTotal;
  });
  const p = getProjectInputs();
  const projectValueVND = p.value * 1e9;
  const actualPct = projectValueVND > 0 ? (totalCost / projectValueVND) * 100 : 0;

  const tfoot = document.getElementById('staffTableFoot');
  if (tfoot) {
    tfoot.innerHTML = '<tr class="row-total">'
      + '<td colspan="8" class="num-r" style="font-size:13px">TỔNG QUỸ LƯƠNG DỰ ÁN</td>'
      + '<td class="tc" style="font-size:14px">'+totalPeople+'</td>'
      + '<td class="tc">—</td>'
      + '<td class="num-r" style="font-size:14px">'+fmt(totalCost)+'</td>'
      + '</tr>';
  }
  renderQuickStats(totalPeople, totalCost, actualPct);
}

// Update riêng 1 row (ô Thành tiền + class active) - KHÔNG re-render bảng
function refreshStaffRow(code){
  const s = STAFF_DATA.find(x => x.code === code);
  if (!s) return;
  const st = staffState[code];
  const totalPerMonth = s.hard + s.welfare;
  const lineTotal = (st.qty || 0) * totalPerMonth * (st.months || 0);

  const totalCell = document.getElementById('total-'+code);
  if (totalCell) {
    totalCell.textContent = lineTotal > 0 ? fmt(lineTotal) : '—';
    totalCell.style.color = lineTotal > 0 ? '#e94560' : '#ccc';
  }
  const row = document.getElementById('row-'+code);
  if (row) {
    if (st.qty > 0) row.classList.add('row-active');
    else row.classList.remove('row-active');
  }
}

function renderQuickStats(totalPeople, totalCost, actualPct){
  const ccm = getCurrentCCM();
  const status = getStatusInfo(actualPct, ccm.rate);
  const cards = [
    { l:'Tổng nhân sự', v: totalPeople + ' người', c:'#0f3460' },
    { l:'Quỹ lương', v: fmtBn(totalCost), c:'#e94560' },
    { l:'% Thực tế / DA', v: fmtPct(actualPct), c: status.color },
    { l:'% CCM đề xuất', v: fmtPct(ccm.rate), c:'#0a9396' },
  ];
  const target = document.getElementById('quickStatsTop');
  if (target) {
    target.innerHTML = cards.map(c =>
      '<div class="card" style="border-left:4px solid '+c.c+'">'
      + '<div class="card-val" style="color:'+c.c+'">'+c.v+'</div>'
      + '<div class="card-label">'+c.l+'</div></div>'
    ).join('');
  }
}

// Live update (oninput): chỉ cập nhật state, ô Thành tiền và footer/cards. KHÔNG re-render input để giữ focus
function updateStaffQtyLive(code, val){
  const v = parseInt(val);
  staffState[code].qty = isNaN(v) ? 0 : v;
  refreshStaffRow(code);
  refreshStaffTotals();
}

function updateStaffMonthsLive(code, val){
  const v = parseFloat(val);
  staffState[code].months = isNaN(v) ? 0 : v;
  refreshStaffRow(code);
  refreshStaffTotals();
}

// Final update (onchange - khi rời focus): xử lý logic phụ (auto-fill months)
function updateStaffQty(code, val){
  const v = parseInt(val) || 0;
  staffState[code].qty = v;
  // Auto-suggest months = duration nếu chưa nhập
  if (v > 0 && !staffState[code].months) {
    const p = getProjectInputs();
    staffState[code].months = p.duration;
    // Cập nhật ô tháng (chỉ ô tháng của dòng này, không re-render cả bảng)
    const monthEl = document.getElementById('month-'+code);
    if (monthEl) monthEl.value = p.duration;
  }
  refreshStaffRow(code);
  refreshStaffTotals();
}

function updateStaffMonths(code, val){
  const v = parseFloat(val) || 0;
  staffState[code].months = v;
  refreshStaffRow(code);
  refreshStaffTotals();
}

function clearAllQty(){
  if (!confirm('Xóa toàn bộ số lượng và số tháng đã nhập?')) return;
  STAFF_DATA.forEach(s => { staffState[s.code] = { qty: 0, months: 0 }; });
  renderStaffTable();
}

function setAllMonthsToDuration(){
  const p = getProjectInputs();
  STAFF_DATA.forEach(s => {
    if (staffState[s.code].qty > 0) staffState[s.code].months = p.duration;
  });
  renderStaffTable();
}

// ===== LOAD DEFAULT STAFF =====
function loadDefaultStaff(){
  const p = getProjectInputs();
  const bucket = getSizeBucket(p.value);
  const preset = getDefaultStaffSuggestion(bucket);
  const region = p.defaultRegion;

  // Reset trước
  STAFF_DATA.forEach(s => { staffState[s.code] = { qty: 0, months: 0 }; });

  preset.forEach(item => {
    // Tìm code phù hợp: nếu có CM/TM thì append region; nếu không thì dùng nguyên
    let targetCode = item.code;
    const hasRegionVariant = STAFF_DATA.find(s => s.code === item.code + region);
    if (hasRegionVariant) targetCode = item.code + region;

    if (staffState[targetCode]) {
      staffState[targetCode].qty = item.qty;
      staffState[targetCode].months = Math.round(p.duration * item.mPct * 10) / 10;
    }
  });
  renderStaffTable();
  alert('✅ Đã tải Cơ cấu Nhân sự đề xuất cho dự án quy mô: ' + sizeLabel(bucket) + '\nMiền: ' + (region === 'CM' ? 'Cùng miền' : 'Trái miền') + '\n\nBạn có thể chỉnh sửa Số lượng và Số tháng theo nhu cầu.');
}

function applyDefaultRegion(){
  // Khi đổi miền mặc định, chuyển các vị trí có biến thể region sang đúng miền
  const p = getProjectInputs();
  const newRegion = p.defaultRegion;
  const otherRegion = newRegion === 'CM' ? 'TM' : 'CM';

  // Lấy các vị trí đang active có region khác
  STAFF_DATA.forEach(s => {
    if (s.region === otherRegion && staffState[s.code].qty > 0) {
      // Chuyển sang biến thể cùng region mới
      const baseCode = s.code.replace(/CM$|TM$/, '');
      const newCode = baseCode + newRegion;
      if (staffState[newCode] !== undefined) {
        staffState[newCode] = { ...staffState[s.code] };
        staffState[s.code] = { qty: 0, months: 0 };
      }
    }
  });
  renderStaffTable();
}

// (updateAll định nghĩa trong SYNC ENGINE ở trên)

// ============================================================
// ===== v1.2: AUTO ALLOCATION (1:4:5, 1:3:6, ...) =====
// ============================================================

// Map mỗi chức danh vào 1 trong 3 ngạch lớn: QL / CV / NV
// QL = Quản lý (lãnh đạo, ra quyết định pháp lý)
//   = GDK, GDDA, CHT, GSAT cấp 2 (an toàn cấp 2 vẫn ở QL vì ít kinh nghiệm cần cấp QL nhỏ)
// CV = Chuyên viên (chuyên môn cao, giám sát kỹ thuật)
//   = CHP (Chỉ huy phó - chuyên viên kỹ thuật cấp cao)
//   = GSAT cấp 1 (An toàn cấp 1)
//   = GSC (Giám sát chính), GS1 (Giám sát thi công cấp 1)
// NV = Nhân viên (thực thi, hỗ trợ)
//   = GS2, TKY, TKHO
function getStaffGroup(code, ngach){
  // Phân loại theo CHỨC DANH thực tế
  // QLCC = Quản lý cấp cao (Giám đốc điều hành, Giám đốc dự án)
  if (code.startsWith('GDK'))   return 'QLCC'; // Giám đốc khối / điều hành
  if (code.startsWith('GDDA'))  return 'QLCC'; // Giám đốc dự án
  // QL = Quản lý công trường (Chỉ huy trưởng)
  if (code.startsWith('CHT'))   return 'QL';
  // CV = Chuyên viên kỹ thuật
  if (code.startsWith('CHP'))   return 'CV';   // Chỉ huy phó
  if (code.startsWith('GSAT1')) return 'CV';   // GSAT cấp 1
  if (code.startsWith('GSC'))   return 'CV';   // Giám sát chính
  if (code.startsWith('GS1'))   return 'CV';   // Giám sát thi công cấp 1
  // NV = Nhân viên thực thi
  if (code.startsWith('GSAT2')) return 'NV';   // GSAT cấp 2 → NV
  if (code.startsWith('GS2'))   return 'NV';   // Giám sát thi công cấp 2
  if (code.startsWith('TKY'))   return 'NV';   // Thư ký
  if (code.startsWith('TKHO'))  return 'NV';   // Thủ kho
  return 'NV';
}

// Độ ưu tiên trong cùng ngạch khi auto-fill (cấp cao trước hay sau tùy ngữ cảnh)
// Đối với QL: ưu tiên CHT/CHP trước GĐDA (vì GĐDA chỉ part-time)
// Đối với CV: GSC trước GS1
// Đối với NV: GS2 trước Thư ký, Thủ kho
function getAutoFillPriority(code){
  // Số càng nhỏ càng được chọn trước
  if (code.startsWith('CHT')) return 1;
  if (code.startsWith('CHP')) return 2;
  if (code.startsWith('GSAT')) return 3;
  if (code.startsWith('GDDA')) return 4;
  if (code.startsWith('GDK')) return 9;
  if (code.startsWith('GSC')) return 1;
  if (code.startsWith('GS1')) return 2;
  if (code.startsWith('GS2')) return 1;
  if (code.startsWith('TKY')) return 2;
  if (code.startsWith('TKHO')) return 3;
  return 5;
}

// Cấp ưu tiên theo quy mô: large → ưu tiên cấp cao, small → cấp thấp
function getLevelByBucket(prefix, bucket){
  // prefix: 'CHT', 'CHP', 'GSC', 'GS', 'GSAT', 'GDDA'
  if (bucket === 'small') return '3';
  if (bucket === 'medium') return '2';
  return '1'; // large
}

function parseRule(ruleStr){
  // '1:3:6' -> {ql:1, cv:3, nv:6}
  const parts = ruleStr.split(':').map(n => parseInt(n) || 0);
  return { ql: parts[0]||0, cv: parts[1]||0, nv: parts[2]||0 };
}

function getCurrentRule(){
  const ruleSel = document.getElementById('spanRule').value;
  if (ruleSel === 'custom') {
    return {
      ql: parseInt(document.getElementById('ratioQL').value) || 0,
      cv: parseInt(document.getElementById('ratioCV').value) || 0,
      nv: parseInt(document.getElementById('ratioNV').value) || 0,
    };
  }
  return parseRule(ruleSel);
}

function allocateByRule(totalCount, rule){
  const sum = rule.ql + rule.cv + rule.nv;
  if (sum === 0) return { ql:0, cv:0, nv:0 };
  // Phân bổ theo tỷ lệ, round, đảm bảo tổng đúng
  const rawQL = totalCount * rule.ql / sum;
  const rawCV = totalCount * rule.cv / sum;
  const rawNV = totalCount * rule.nv / sum;
  let ql = Math.round(rawQL);
  let cv = Math.round(rawCV);
  let nv = totalCount - ql - cv;
  if (nv < 0) { nv = 0; cv = totalCount - ql; }
  // Đảm bảo có tối thiểu 1 QL
  if (ql === 0 && totalCount > 0) { ql = 1; nv = Math.max(0, nv - 1); }
  return { ql, cv, nv };
}

function suggestStaffCount(){
  const p = getProjectInputs();
  const bucket = getSizeBucket(p.value);
  // Gợi ý tổng nhân sự theo quy mô
  const suggestions = { small: 10, medium: 18, large: 32 };
  const v = suggestions[bucket];
  document.getElementById('totalStaffCount').value = v;
  updateAutoAllocation();
  alert('💡 Gợi ý theo Quy mô '+sizeLabel(bucket)+':\n• Quy mô <100 tỷ: ~10 người\n• Quy mô 100-250 tỷ: ~18 người\n• Quy mô >250 tỷ: ~32 người\n\nĐã đặt: '+v+' người (có thể chỉnh thủ công).');
}

function onCustomRatioChange(){
  document.getElementById('spanRule').value = 'custom';
  updateAutoAllocation();
}

function updateAutoAllocation(){
  // Sync inputs khi không phải custom
  const ruleStr = document.getElementById('spanRule').value;
  if (ruleStr !== 'custom') {
    const r = parseRule(ruleStr);
    document.getElementById('ratioQL').value = r.ql;
    document.getElementById('ratioCV').value = r.cv;
    document.getElementById('ratioNV').value = r.nv;
  }

  const total = parseInt(document.getElementById('totalStaffCount').value) || 0;
  const rule = getCurrentRule();
  const alloc = allocateByRule(total, rule);

  // Tính quỹ lương dự kiến cho mỗi ngạch (dùng lương TB của ngạch)
  const p = getProjectInputs();
  const bucket = getSizeBucket(p.value);
  const region = p.defaultRegion;
  const dur = p.duration;

  // Lương TB theo ngạch (lấy lương cấp tương ứng quy mô)
  const avgByGroup = computeAvgSalaryByGroup(bucket, region);

  const costQL = alloc.ql * avgByGroup.QL * dur;
  const costCV = alloc.cv * avgByGroup.CV * dur;
  const costNV = alloc.nv * avgByGroup.NV * dur;
  const costTotal = costQL + costCV + costNV;

  const sum = rule.ql + rule.cv + rule.nv;
  const pctQL = sum>0 ? (rule.ql/sum*100) : 0;
  const pctCV = sum>0 ? (rule.cv/sum*100) : 0;
  const pctNV = sum>0 ? (rule.nv/sum*100) : 0;

  // Tỷ lệ quỹ lương thực tế (khác tỷ lệ đầu người vì lương khác nhau)
  const cPctQL = costTotal>0 ? (costQL/costTotal*100) : 0;
  const cPctCV = costTotal>0 ? (costCV/costTotal*100) : 0;
  const cPctNV = costTotal>0 ? (costNV/costTotal*100) : 0;

  let html = '<div class="alloc-grid">';
  html += '<div class="alloc-card ql"><div class="ratio">QL · Quản lý · ×'+rule.ql+'</div><div class="count" style="color:#92400e">'+alloc.ql+'</div><div class="label">người ('+pctQL.toFixed(0)+'% đầu người)</div><div class="pct" style="color:#92400e">💰 '+cPctQL.toFixed(1)+'% quỹ lương</div></div>';
  html += '<div class="alloc-card cv"><div class="ratio">CV · Chuyên viên · ×'+rule.cv+'</div><div class="count" style="color:#1e40af">'+alloc.cv+'</div><div class="label">người ('+pctCV.toFixed(0)+'% đầu người)</div><div class="pct" style="color:#1e40af">💰 '+cPctCV.toFixed(1)+'% quỹ lương</div></div>';
