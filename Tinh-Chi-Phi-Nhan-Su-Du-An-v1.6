function computeAvgSalaryByGroup(bucket, region){
  // Lương TB theo ngạch dựa trên các vị trí thực tế trong nhóm (cùng phân loại với getStaffGroup)
  const lvl = { small:'3', medium:'2', large:'1' }[bucket];

  const salaryOf = (code) => {
    const s = STAFF_DATA.find(x => x.code === code);
    return s ? (s.hard + s.welfare) : 0;
  };

  const findCode = (prefix, level) => {
    // Tìm với region trước
    const withReg = STAFF_DATA.find(s => s.code === prefix + level + region);
    if (withReg) return prefix + level + region;
    const noReg = STAFF_DATA.find(s => s.code === prefix + level);
    if (noReg) return prefix + level;
    // Fallback - bất kỳ cấp nào có prefix
    const any = STAFF_DATA.find(s => s.code.startsWith(prefix));
    return any ? any.code : null;
  };

  // QL = CHT (cấp tương ứng) + GDDA (cấp tương ứng)
  const cht = salaryOf(findCode('CHT', lvl));
  const gdda = salaryOf(findCode('GDDA', lvl));
  const qlAvg = Math.round((cht + gdda) / 2);

  // CV = CHP + GSAT1 + GSC + GS1 (cấp tương ứng, GSAT1 luôn cấp 1)
  const chp = salaryOf(findCode('CHP', lvl));
  const gsat1 = salaryOf(findCode('GSAT', '1'));
  const gsc = salaryOf(findCode('GSC', lvl === '3' ? '2' : lvl));  // GSC chỉ có cấp 1,2
  const gs1 = salaryOf(findCode('GS1', '1'));  // GS thi công cấp 1
  const cvAvg = Math.round((chp + gsat1 + gsc + gs1) / 4);

  // NV = GS2 + GSAT2 + TKY + TKHO
  const gs2 = salaryOf(findCode('GS2', '2'));
  const gsat2 = salaryOf(findCode('GSAT', '2'));
  const tky = salaryOf(findCode('TKY', ''));
  const tkho = salaryOf(findCode('TKHO', ''));
  const nvAvg = Math.round((gs2 + gsat2 + tky + tkho) / 4);

  return { QL: qlAvg, CV: cvAvg, NV: nvAvg };
}

