// Map input-id → state key
const INPUT_STATE_MAP = {
  'projectName':    'projectName',
  'projectOwner':   'projectOwner',
  'projectType':    'projectType',
  'projectValue':   'projectValue',
  'projectDuration':'duration',
  'defaultRegion':  'region',
  'qcType':         'projectType',   // mirror of projectType
  'qcGTT':          'projectValue',  // mirror of projectValue
  'qcT':            'duration',      // mirror of duration
  'qcL':            'qcL',
  'qcR':            'qcR',
  'qcN':            'qcN',
  'qcTimeCoef':     'timeCoef',
  'spanRule':       'spanRule',
  'totalStaffCount':'totalStaff',
};

// Gọi khi bất kỳ input thay đổi — cập nhật state rồi sync toàn bộ mirror
function syncFromInput(sourceId){
  const el = document.getElementById(sourceId);
  if (!el) return;
  const stateKey = INPUT_STATE_MAP[sourceId];
  if (!stateKey) return;

  // Parse value
  let val;
  if (el.type === 'number') {
    val = sourceId === 'qcN' ? (parseInt(el.value) || null) : (parseFloat(el.value) || 0);
  } else {
    val = el.value;
  }
  APP_STATE[stateKey] = val;

  // Sync mirrors (không sync ngược về input đang focus)
  syncMirrors(sourceId, stateKey, val);

  // Re-render tất cả panels đang active + tính toán
  updateAll();
}

// Map stateKey → tất cả input IDs mirror nó
const STATE_MIRRORS = {
  projectType:  ['projectType','qcType'],
  projectValue: ['projectValue','qcGTT'],
  duration:     ['projectDuration','qcT'],
  qcL:          ['qcL'],
  qcR:          ['qcR'],
  qcN:          ['qcN'],
  timeCoef:     ['qcTimeCoef'],
  spanRule:     ['spanRule'],
  totalStaff:   ['totalStaffCount'],
};

function syncMirrors(sourceId, stateKey, val){
  const mirrors = STATE_MIRRORS[stateKey] || [];
  mirrors.forEach(id => {
    if (id === sourceId) return; // không sync ngược
    const el = document.getElementById(id);
    if (!el || document.activeElement === el) return;
    el.value = val === null ? '' : val;
  });
}

// Event type/region đặc biệt → cần load defaults L, R
function onProjectTypeChange(){
  const val = document.getElementById('projectType').value;
  APP_STATE.projectType = val;
  document.getElementById('qcType').value = val;
  // Load L, R chuẩn theo loại hình
  const d = QC_DEFAULTS[val];
  if (d) {
    APP_STATE.qcL = d.L;
    APP_STATE.qcR = d.R;
    safeSet('qcL', d.L);
    safeSet('qcR', d.R.toFixed(2));
  }
  updateAll();
}

function onQuickTypeChange(){
  const val = document.getElementById('qcType').value;
  APP_STATE.projectType = val;
  document.getElementById('projectType').value = val;
  const d = QC_DEFAULTS[val];
  if (d) {
    APP_STATE.qcL = d.L;
    APP_STATE.qcR = d.R;
    safeSet('qcL', d.L);
    safeSet('qcR', d.R.toFixed(2));
  }
  updateAll();
}

function reloadQuickDefaults(){
  const t = APP_STATE.projectType;
  const d = QC_DEFAULTS[t];
  if (!d) return;
  APP_STATE.qcL = d.L;
  APP_STATE.qcR = d.R;
  APP_STATE.qcN = null;
  safeSet('qcL', d.L);
  safeSet('qcR', d.R.toFixed(2));
  safeSet('qcN', '');
  updateAll();
}

