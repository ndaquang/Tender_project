<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Phần Mềm Tính Chi Phí Nhân Sự Dự Án — v1.0</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Segoe UI','Helvetica Neue',Arial,sans-serif;background:#f0f2f5;color:#1a1a2e;font-size:13px;line-height:1.5}
.root{max-width:1400px;margin:0 auto;padding:16px 12px}
.header{background:linear-gradient(135deg,#0f3460,#16213e,#1a1a2e);border-radius:14px;padding:22px 20px 16px;color:#fff;margin-bottom:14px}
.header h1{font-size:18px;font-weight:700;margin:0}
.header p{font-size:11px;opacity:.7;margin:2px 0 0}
.header-row{display:flex;align-items:center;gap:10px}
.logo{width:36px;height:36px;border-radius:9px;background:linear-gradient(135deg,#e94560,#ff6b6b);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:15px;flex-shrink:0;color:#fff}
.tags{display:flex;gap:5px;margin-top:10px;flex-wrap:wrap;font-size:10px;opacity:.6}
.tags span{background:rgba(255,255,255,.1);padding:2px 8px;border-radius:14px}

.tab-bar{display:flex;gap:4px;margin-bottom:12px;background:#eef1f6;border-radius:10px;padding:3px;flex-wrap:wrap}
.tab-btn{flex:1;min-width:120px;padding:9px 6px;border-radius:8px;border:none;cursor:pointer;font-weight:600;font-size:12px;background:transparent;color:#555;transition:all .2s}
.tab-btn.active{background:#16213e;color:#fff}

.tab-panel{display:none}
.tab-panel.active{display:block}

/* Project input section */
.section-box{background:#fff;border-radius:12px;padding:16px;margin-bottom:12px;box-shadow:0 1px 6px rgba(0,0,0,.04);border:1px solid #e8e8ee}
.section-title{font-weight:700;font-size:13px;margin-bottom:10px;color:#0f3460;border-bottom:2px solid #eef1f6;padding-bottom:6px}
.input-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px}
.input-group{display:flex;flex-direction:column;gap:4px}
.input-group label{font-size:11px;font-weight:700;color:#555}
.input-group input,.input-group select{padding:9px 12px;border:1.5px solid #dde;border-radius:9px;font-size:13px;outline:none;background:#f8f9fc;transition:border-color .15s,background .15s}
.input-group input:focus,.input-group select:focus{border-color:#0f3460;background:#fff;box-shadow:0 0 0 3px rgba(15,52,96,.08)}

/* Table */
.tbl-wrap{overflow-x:auto;border-radius:10px;border:1px solid #e8e8ee;box-shadow:0 1px 6px rgba(0,0,0,.03);margin-bottom:12px;background:#fff}
table{width:100%;border-collapse:collapse;min-width:1050px}
thead tr{background:#16213e;color:#fff}
th{padding:10px 8px;text-align:left;font-weight:600;font-size:11px;white-space:nowrap}
td{padding:6px 8px;border-bottom:1px solid #eee;font-size:12px}
tbody tr{transition:background .15s}
tbody tr:nth-child(even){background:#f7f8fb}
tbody tr:hover{background:#eef1f8!important}
.row-active{background:#fff8e8!important}
.row-active:nth-child(even){background:#fff8e8!important}

.badge{display:inline-block;background:#e0e5f0;padding:2px 7px;border-radius:5px;font-size:10px;font-weight:600;color:#0f3460}
.badge-cm{background:#dbeafe;color:#1e40af}
.badge-tm{background:#fee2e2;color:#991b1b}
.badge-qlcc{background:#ede9fe;color:#5b21b6;font-weight:800}
.badge-ql{background:#dcfce7;color:#166534}
.badge-cv{background:#fef3c7;color:#854d0e}
.badge-nv{background:#f3e8ff;color:#6b21a8}

.num-r{text-align:right;font-variant-numeric:tabular-nums}
.tc{text-align:center}

/* Inputs in table */
.qty-input,.month-input{width:70px;text-align:center;font-weight:700;font-size:13px;padding:5px 6px;border:1.5px solid #dde;border-radius:7px;background:#fffbe6;outline:none;-moz-appearance:textfield;transition:border-color .15s,background .15s}
.qty-input::-webkit-outer-spin-button,.qty-input::-webkit-inner-spin-button,.month-input::-webkit-outer-spin-button,.month-input::-webkit-inner-spin-button{-webkit-appearance:none;margin:0}
.qty-input:focus,.month-input:focus{border-color:#e94560;background:#fff8e8;box-shadow:0 0 0 3px rgba(233,69,96,.08)}

/* Summary cards */
.summary-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px;margin-bottom:12px}
.card{background:#fff;border-radius:10px;padding:14px 16px;box-shadow:0 1px 6px rgba(0,0,0,.04)}
.card-val{font-size:20px;font-weight:800}
.card-label{font-size:10px;color:#777;margin-top:2px;text-transform:uppercase;letter-spacing:.5px}
.card-sub{font-size:11px;color:#888;margin-top:4px}

/* Reference table CCM */
.ccm-table{width:100%;border-collapse:collapse;font-size:12px}
.ccm-table th{background:#fef9c3;color:#854d0e;padding:8px;text-align:center;font-size:11px;border:1px solid #fde68a}
.ccm-table td{padding:7px 8px;border:1px solid #fde68a;text-align:center}
.ccm-table .label{font-weight:700;background:#fffbeb;text-align:left}
.ccm-table .pct{font-weight:700;color:#0f3460}
.ccm-table .pct-highlight{background:#dbeafe;color:#1e40af;font-weight:800}

/* Action buttons */
.btn{padding:9px 16px;border-radius:8px;border:none;cursor:pointer;font-weight:700;font-size:12px;color:#fff;transition:all .2s}
.btn-primary{background:#0f3460}
.btn-primary:hover{background:#16213e}
.btn-success{background:#0a9396}
.btn-success:hover{background:#087a7e}
.btn-danger{background:#e94560}
.btn-danger:hover{background:#d13350}
.btn-secondary{background:#aaa}
.btn-secondary:hover{background:#888}
.btn-purple{background:#7b2cbf}
.btn-purple:hover{background:#6a1b9a}

.action-bar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px}

/* Result alert */
.alert{padding:14px 16px;border-radius:10px;margin-bottom:12px;font-size:13px;line-height:1.6}
.alert-success{background:#dcfce7;border:1.5px solid #86efac;color:#166534}
.alert-warning{background:#fef3c7;border:1.5px solid #fcd34d;color:#854d0e}
.alert-danger{background:#fee2e2;border:1.5px solid #fca5a5;color:#991b1b}
.alert-info{background:#dbeafe;border:1.5px solid #93c5fd;color:#1e40af}
.alert b{font-weight:800}

/* Footer */
.footer{margin-top:14px;padding:12px 14px;background:#f8f9fc;border-radius:10px;font-size:11px;color:#777;line-height:1.7;border:1px solid #e8e8ee}

/* Region toggle inline in row */
.region-toggle{display:inline-flex;gap:2px;background:#eef1f6;border-radius:6px;padding:2px}
.region-toggle button{padding:3px 8px;border:none;background:transparent;cursor:pointer;font-size:10px;font-weight:600;color:#666;border-radius:4px;transition:all .15s}
.region-toggle button.active{background:#16213e;color:#fff}

.notice{font-size:11px;color:#888;font-style:italic;margin-top:6px}

/* Print-friendly */
@media print{
  body{background:#fff}
  .tab-bar,.action-bar,.btn,.no-print{display:none!important}
  .tab-panel{display:block!important}
}

@media(max-width:640px){
  .header h1{font-size:15px}
  .summary-grid{grid-template-columns:repeat(2,1fr)}
  .tab-bar{gap:2px}
  .tab-btn{font-size:11px;min-width:90px}
}

.row-total{background:#0f3460!important;color:#fff;font-weight:800}
.row-total td{color:#fff!important;border-bottom:none}

.scope-tag{display:inline-block;font-size:9px;padding:1px 5px;border-radius:3px;background:#16213e;color:#fff;margin-left:4px;font-weight:600}

.chart-bar{display:inline-block;height:12px;background:linear-gradient(90deg,#0a9396,#0f3460);border-radius:3px;vertical-align:middle;margin-right:6px;min-width:2px}

.info-row{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px dashed #eee;font-size:12px}
.info-row:last-child{border-bottom:none}
.info-row b{color:#0f3460}

/* === v1.2: Auto-allocation + PMBOK === */
.alloc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:8px}
.alloc-card{padding:14px;border-radius:10px;text-align:center;border:2px solid}
.alloc-card.ql{background:#fef3c7;border-color:#f59e0b}
.alloc-card.cv{background:#dbeafe;border-color:#3b82f6}
.alloc-card.nv{background:#dcfce7;border-color:#22c55e}
.alloc-card .ratio{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;opacity:.7}
.alloc-card .count{font-size:28px;font-weight:800;line-height:1.2;margin:4px 0}
.alloc-card .label{font-size:11px;color:#555}
.alloc-card .pct{font-size:13px;font-weight:700;margin-top:6px}

.rule-compare-tbl{width:100%;border-collapse:collapse;font-size:12px}
.rule-compare-tbl th{background:#1e3a8a;color:#fff;padding:8px;font-size:11px;text-align:center}
.rule-compare-tbl td{padding:7px 8px;border-bottom:1px solid #e5e7eb;text-align:center}
.rule-compare-tbl td.rule-name{text-align:left;font-weight:700;background:#f1f5f9}
.rule-compare-tbl tr.active-rule{background:#fef3c7}
.rule-compare-tbl tr.active-rule td{background:#fef3c7!important;font-weight:700}

/* RACI matrix */
.raci-tbl{width:100%;border-collapse:collapse;font-size:11px}
.raci-tbl th{background:#6b21a8;color:#fff;padding:7px 4px;font-size:10px;text-align:center;border:1px solid #581c87}
.raci-tbl th:first-child{text-align:left;background:#581c87}
.raci-tbl td{padding:6px;border:1px solid #e5e7eb;text-align:center}
.raci-tbl td:first-child{text-align:left;font-weight:600;background:#faf5ff;font-size:12px}
.raci-tbl td.r{background:#fee2e2;color:#991b1b;font-weight:800}
.raci-tbl td.a{background:#dbeafe;color:#1e40af;font-weight:800}
.raci-tbl td.c{background:#fef3c7;color:#854d0e;font-weight:700}
.raci-tbl td.i{background:#e0e7ff;color:#3730a3;font-weight:600}

/* Process timeline */
.timeline{display:flex;align-items:stretch;border-radius:8px;overflow:hidden;margin:10px 0;min-height:44px}
.timeline-phase{display:flex;align-items:center;justify-content:center;padding:8px 6px;color:#fff;font-size:11px;font-weight:700;text-align:center;line-height:1.3;position:relative}
.timeline-phase .phase-pct{font-size:10px;opacity:.85;display:block;font-weight:600}

.process-table{width:100%;border-collapse:collapse;font-size:12px;margin-top:10px}
.process-table th{background:#7b2cbf;color:#fff;padding:8px;font-size:11px;text-align:left}
.process-table td{padding:8px;border-bottom:1px solid #eee}
.process-table td.tc{text-align:center}
.process-table .phase-name{font-weight:700;color:#6b21a8}

/* ISO 21502 role cards */
.iso-role-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px}
.iso-role-card{padding:12px;background:#f5f3ff;border-left:4px solid #7b2cbf;border-radius:8px}
.iso-role-card .role-title{font-weight:800;color:#6b21a8;font-size:12px;margin-bottom:4px;text-transform:uppercase;letter-spacing:.3px}
.iso-role-card .role-desc{font-size:11px;color:#666;margin-bottom:6px;font-style:italic}
.iso-role-card .role-codes{font-size:11px;line-height:1.7}
.iso-role-card .role-codes b{color:#0f3460;font-family:monospace}
</style>
</head>
<body>
<div class="root">

  <!-- HEADER -->
  <div class="header">
    <div class="header-row">
      <div class="logo">NS</div>
      <div>
        <h1>Phần Mềm Tính Chi Phí Nhân Sự Dự Án</h1>
        <p>3 nhóm CCM (NX/CT/TT) | Tính Phổ Thông | Flow Diagram | Đồng bộ State | PMBOK + ISO 21502 | v1.6</p>
      </div>
    </div>
    <div class="tags">
      <span>3 nhóm: Nhà xưởng / Cao tầng / Thấp tầng</span>
      <span>State đồng bộ toàn tab</span>
      <span>Flow diagram trực quan</span>
      <span>5 công thức Định biên 2026</span>
      <span>Hệ số biến động thời gian</span>
      <span>PMBOK + ISO 21502</span>
    </div>
  </div>

  <!-- TAB BAR -->
  <div class="tab-bar">
    <button class="tab-btn active" onclick="switchTab('input')">📋&nbsp;Thông tin DA</button>
    <button class="tab-btn" onclick="switchTab('quick')">⚡&nbsp;Tính Phổ Thông</button>
    <button class="tab-btn" onclick="switchTab('auto')">🎯&nbsp;Phân bổ Tự động</button>
    <button class="tab-btn" onclick="switchTab('staff')">👥&nbsp;Cơ cấu NS</button>
    <button class="tab-btn" onclick="switchTab('pmbok')">📐&nbsp;PMBOK / ISO</button>
    <button class="tab-btn" onclick="switchTab('summary')">📊&nbsp;Tổng hợp</button>
    <button class="tab-btn" onclick="switchTab('report')">📈&nbsp;Báo cáo</button>
  </div>

  <!-- FLOW INDICATOR — luôn hiển thị, làm nổi bật tab hiện tại -->
  <div id="flowBar" style="display:flex;align-items:center;gap:0;margin-bottom:12px;background:#fff;border-radius:10px;border:1px solid #e8e8ee;overflow:hidden;font-size:11px;flex-wrap:wrap"></div>

  <!-- ============== TAB 1: PROJECT INPUT ============== -->
  <div class="tab-panel active" id="tab-input">

    <div class="section-box">
      <div class="section-title">🏗️ Thông số đầu vào dự án</div>
      <div class="input-grid">
        <div class="input-group">
          <label>Tên Dự án</label>
          <input type="text" id="projectName" placeholder="VD: Chung cư ABC..." value="">
        </div>
        <div class="input-group">
          <label>Chủ đầu tư</label>
          <input type="text" id="projectOwner" placeholder="VD: Công ty XYZ..." value="">
        </div>
        <div class="input-group">
          <label>Loại hình dự án *</label>
          <select id="projectType" onchange="onProjectTypeChange()">
            <option value="NX">Nhà xưởng / Factory</option>
            <option value="CT" selected>Cao tầng / High-Rise</option>
            <option value="TT">Thấp tầng / Low-Rise</option>
          </select>
        </div>
        <div class="input-group">
          <label>Quy mô (Giá trị Doanh thu DA) — Tỷ VND *</label>
          <input type="number" id="projectValue" min="0" step="1" value="150" oninput="syncFromInput('projectValue')">
        </div>
        <div class="input-group">
          <label>Tiến độ dự án (tháng) *</label>
          <input type="number" id="projectDuration" min="1" step="1" value="18" oninput="syncFromInput('projectDuration')">
        </div>
        <div class="input-group">
          <label>Miền thi công (mặc định)</label>
          <select id="defaultRegion" onchange="syncFromInput('defaultRegion')">
            <option value="CM">Cùng miền (CM)</option>
            <option value="TM">Trái miền (TM)</option>
          </select>
        </div>
      </div>
      <div class="notice">* Các trường bắt buộc. Số liệu tỷ lệ % CCM sẽ tự động phân quy mô: &lt;100 tỷ | 100-250 tỷ | &gt;250 tỷ</div>
    </div>

    <!-- CCM Reference -->
    <div class="section-box">
      <div class="section-title">📑 Bảng tham chiếu Tỷ lệ % CCM đề xuất</div>
      <div style="overflow-x:auto">
        <table class="ccm-table" id="ccmTable">
          <thead>
            <tr>
              <th rowspan="2">Loại hình</th>
              <th colspan="3">Quy mô Doanh thu Dự án</th>
            </tr>
            <tr>
              <th>0 &lt; DT &lt; 100 tỷ</th>
              <th>100 ≤ DT ≤ 250 tỷ</th>
              <th>DT &gt; 250 tỷ</th>
            </tr>
          </thead>
          <tbody id="ccmTableBody">
            <!-- rendered by JS -->
          </tbody>
        </table>
      </div>
      <div class="notice">💡 Ô được tô đậm là tỷ lệ áp dụng cho dự án hiện tại (theo Loại hình + Quy mô đã chọn). Nhấp vào ô để tùy chỉnh.</div>
    </div>

    <!-- SCOPE & OVERLAP ADJUSTMENT -->
    <div class="section-box" style="border:1.5px solid #fcd34d;background:linear-gradient(135deg,#fffbeb,#fef9c3)">
      <div class="section-title" style="color:#854d0e;border-bottom-color:#fde68a">⚙️ Hiệu chỉnh % CCM cho High-Rise (Scope + Overlap)</div>
      <div class="notice" style="margin-top:0;margin-bottom:10px;color:#92400e">
        Khi CDT chia gói (chỉ thô / hoàn thiện / M&amp;E) và/hoặc hoàn thiện chồng chéo kết cấu, bộ máy nhân sự vẫn cần đầy đủ. Tỷ lệ % CCM cần điều chỉnh để phản ánh thực tế.
      </div>

      <div class="input-grid">
        <div class="input-group">
          <label>🎯 Kịch bản nhanh (chọn để tự động áp hệ số)</label>
          <select id="scenarioPreset" onchange="applyScenarioPreset()">
            <option value="custom">— Tùy chỉnh —</option>
            <option value="base">Chuẩn: Tổng thầu, không chồng chéo (×1.00)</option>
            <option value="easy">Dễ: Tổng thầu + chồng chéo nhẹ (×1.08)</option>
            <option value="medium" selected>Phổ biến: Chia gói + chồng chéo TB (×1.18)</option>
            <option value="hard">Khó: Chỉ thô + chồng chéo cao (×1.32)</option>
            <option value="finish">Rất khó: Chỉ hoàn thiện + overlap cao (×1.45)</option>
            <option value="me">M&amp;E riêng + overlap cao (×1.55)</option>
          </select>
        </div>

        <div class="input-group">
          <label>📦 Phạm vi công việc (Scope)</label>
          <select id="scopeType" onchange="onScopeOverlapChange()">
            <option value="full" data-coef="1.00">Tổng thầu — Thô + Hoàn thiện + M&amp;E (×1.00)</option>
            <option value="th_ht" data-coef="1.12">Thô + Hoàn thiện (không M&amp;E) (×1.12)</option>
            <option value="tho" data-coef="1.20" selected>Chỉ Thô — Kết cấu + Xây tô (×1.20)</option>
            <option value="ht" data-coef="1.28">Chỉ Hoàn thiện (×1.28)</option>
            <option value="me" data-coef="1.32">Chỉ M&amp;E (×1.32)</option>
          </select>
        </div>

        <div class="input-group">
          <label>🔄 Mức chồng chéo Hoàn thiện-Kết cấu (Overlap)</label>
          <select id="overlapLevel" onchange="onScopeOverlapChange()">
            <option value="none" data-coef="1.00">Không chồng chéo — Tuần tự (×1.00)</option>
            <option value="light" data-coef="1.08">Chồng chéo nhẹ — 10-30% (×1.08)</option>
            <option value="medium" data-coef="1.14" selected>Trung bình — 30-50% (×1.14)</option>
            <option value="high" data-coef="1.24">Cao — &gt;50%, siêu cao tầng (×1.24)</option>
          </select>
        </div>

        <div class="input-group">
          <label>✏️ Hệ số tổng (có thể chỉnh tay)</label>
          <input type="number" id="totalCoef" min="0.5" max="3" step="0.01" value="1.18" oninput="onTotalCoefChange()">
        </div>
      </div>

      <!-- Result preview -->
      <div id="adjustedRatePreview" style="margin-top:12px;padding:12px 14px;background:#fff;border-radius:10px;border:2px dashed #f59e0b">
        <!-- Filled by JS -->
      </div>

      <div class="notice" style="margin-top:8px;color:#92400e">
        💡 Hệ số chỉ áp dụng cho <b>High-Rise (cao tầng)</b>. Khi chọn "Kịch bản nhanh" thì Scope + Overlap sẽ tự cập nhật; bạn vẫn có thể tinh chỉnh từng dropdown hoặc nhập trực tiếp ô "Hệ số tổng".
      </div>
    </div>

    <div class="action-bar">
      <button class="btn btn-success" onclick="loadDefaultStaff()">🔄 Áp dụng Cơ cấu Nhân sự Đề xuất</button>
      <button class="btn btn-primary" onclick="switchTab('staff')">➡️ Tiếp tục: Nhập Cơ cấu Nhân sự</button>
    </div>

  </div>

  <!-- ============== TAB 2: STAFF STRUCTURE ============== -->
  <div class="tab-panel" id="tab-staff">

    <div class="summary-grid" id="quickStatsTop"></div>

    <div class="section-box">
      <div class="section-title">👥 Cơ cấu Nhân sự dự án (Nhập số lượng + số tháng có mặt)</div>
      <div class="action-bar" style="margin-bottom:8px">
        <button class="btn btn-success" onclick="loadDefaultStaff()">🔄 Tải Đề xuất theo Quy mô</button>
        <button class="btn btn-secondary" onclick="clearAllQty()">🗑️ Xóa toàn bộ Số lượng</button>
        <button class="btn btn-primary" onclick="setAllMonthsToDuration()">⏱️ Đặt Số tháng = Tiến độ DA</button>
      </div>
      <div class="tbl-wrap">
        <table>
          <thead>
            <tr>
              <th style="width:40px">STT</th>
              <th>Code</th>
              <th>Đối tượng (Chức danh)</th>
              <th class="tc">Nhóm</th>
              <th class="tc">Miền</th>
